//==============================================================================
// GFX1250 (RDNA4) INSTRUCTION FORMAT DEFINITIONS
//
// Architecture metadata (must appear before DEF_FORMAT)
//------------------------------------------------------------------------------
DEF_ARCH(Gfx1250,
    .major = 12, .minor = 5, .stepping = 0,
    .wavefront = 32,
    .maxVGPR = 256, .maxSGPR = 102, .maxAGPR = 0,
    .defaultCycle = 1, .defaultLatency = 1)

//------------------------------------------------------------------------------
// This file defines default properties for each instruction encoding format.
// Instructions using a format inherit its defaults and can optionally override them.
//
// Each DEF_FORMAT defines:
//   - modifiers: List of allowed instruction modifiers
//   - unit: Default execution unit (VALU, SALU, MatrixUnit, etc.)
//   - encoding: Instruction encoding size in bits
//   - maxOperands: Maximum number of operands
//   - pipeline: Pipeline stage (optional, e.g., VP0, VP1)
//   - flags: Instruction classification flags (optional)
//
// NOTE: Only existing flags from include/stinkytofu/hardware/Flags.def are used.
//==============================================================================

//------------------------------------------------------------------------------
// VECTOR ALU FORMATS
//------------------------------------------------------------------------------

// Vector 1-operand (32-bit encoding)
// Used for: v_mov, v_not, v_cvt_*, etc.
DEF_FORMAT(VOP1,
    .modifiers = {},
    .unit = VALU,
    .encoding = {32},
    .maxOperands = 2,  // dst + src
    .flags = {VALU},
)

// Vector 2-operand (32-bit encoding)
// Used for: v_add_f32, v_mul_f32, etc.
DEF_FORMAT(VOP2,
    .modifiers = {},
    .unit = VALU,
    .encoding = {32},
    .maxOperands = 3,  // dst + src0 + src1
    .flags = {VALU},
)

// Vector 3-operand (64-bit encoding with modifiers)
// Used for: v_fma_f32, v_mad_f32, etc.
DEF_FORMAT(VOP3,
    .modifiers = {},  // TODO: Implement modifier system
    .unit = VALU,
    .encoding = {64},
    .maxOperands = 4,  // dst + src0 + src1 + src2
    .flags = {VALU},
)

// Vector compare (32-bit encoding)
// Used for: v_cmp_eq_f32, v_cmp_lt_i32, etc.
DEF_FORMAT(VOPC,
    .modifiers = {},
    .unit = VALU,
    .encoding = {32},
    .maxOperands = 2,  // src0 + src1 (result to VCC)
    .flags = {VALU},
)

// Vector 3-operand packed (64-bit encoding) - hardware ISA format (gfx12/RDNA4)
// Used as encoding base for WMMA/SWMMA/MXWMMA on Gfx1250 (reference: gfx12 / 9070XT)
DEF_FORMAT(VOP3P,
    .modifiers = {},
    .unit = VALU,
    .encoding = {64},
    .maxOperands = 4,
    .flags = {},
)

//------------------------------------------------------------------------------
// SCALAR ALU FORMATS
//------------------------------------------------------------------------------

// Scalar 1-operand (32-bit encoding)
// Used for: s_mov_b32, s_not_b32, etc.
DEF_FORMAT(SOP1,
    .modifiers = {},
    .unit = SALU,
    .encoding = {32},
    .maxOperands = 2,  // dst + src
    .flags = {SALU},
)

// Scalar 2-operand (32-bit encoding)
// Used for: s_add_u32, s_and_b32, etc.
DEF_FORMAT(SOP2,
    .modifiers = {},
    .unit = SALU,
    .encoding = {32},
    .maxOperands = 3,  // dst + src0 + src1
    .flags = {SALU},
)

// Scalar compare (32-bit encoding)
// Used for: s_cmp_eq_i32, s_cmp_lt_u32, etc.
DEF_FORMAT(SOPC,
    .modifiers = {},
    .unit = SALU,
    .encoding = {32},
    .maxOperands = 2,  // src0 + src1 (result to SCC)
    .flags = {SALU},
)

// Scalar program flow (32-bit encoding)
// Used for: s_branch, s_cbranch_*, s_waitcnt, s_barrier, etc.
DEF_FORMAT(SOPP,
    .modifiers = {},
    .unit = BranchUnit,
    .encoding = {32},
    .maxOperands = 1,  // label or immediate
)

//------------------------------------------------------------------------------
// MATRIX FORMATS (GFX1250 / RDNA4: WMMA only; no MFMA) - inherit from VOP3P
//------------------------------------------------------------------------------
// Gfx1250 uses WMMA/SWMMA/MXWMMA (gfx12-style matrix ops); encoding base is VOP3P.

// Wave Matrix Multiply-Accumulate: same 64-bit encoding as VOP3P, Matrix unit
DEF_FORMAT(WMMA,
    .parent = VOP3P,
    .unit = MatrixUnit,
    .maxOperands = 4,
    .flags = {WMMA},
)

// Sparse Wave Matrix Multiply-Accumulate
DEF_FORMAT(SWMMA,
    .parent = VOP3P,
    .unit = MatrixUnit,
    .maxOperands = 5,
    .flags = {SWMMA},
)

// MX Format Wave Matrix Multiply-Accumulate (v_mxwmma_*, v_wmma_scale*)
DEF_FORMAT(MXWMMA,
    .parent = VOP3P,
    .unit = MatrixUnit,
    .maxOperands = 4,
    .flags = {MXWMMA},
)

//------------------------------------------------------------------------------
// MEMORY FORMATS (hardware encodings: MUBUF, FLAT, DS, SMRD per AMD ISA / gfx12)
//------------------------------------------------------------------------------

// MUBUF - untyped buffer (hardware encoding); buffer_* instructions use this
DEF_FORMAT(MUBUF,
    .modifiers = {},
    .unit = BufferMemory,
    .encoding = {64},
    .maxOperands = 5,
    .flags = {},
)

// DS - Data Share / LDS (hardware encoding)
// Used for: ds_read_*, ds_write_*, ds_add_*, etc.
DEF_FORMAT(DS,
    .modifiers = {},
    .unit = LDS,
    .encoding = {64},
    .maxOperands = 3,
    .flags = {},
)

// FLAT - flat memory (hardware encoding)
// Used for: flat_load_*, flat_store_*, flat_atomic_*
DEF_FORMAT(FLAT,
    .modifiers = {},
    .unit = GlobalMemory,
    .encoding = {64},
    .maxOperands = 3,
    .flags = {},
)

// SMRD - Scalar Memory Read/Write (hardware encoding, gfx12 uses 64-bit)
DEF_FORMAT(SMRD,
    .modifiers = {},
    .unit = ScalarMemory,
    .encoding = {64},
    .maxOperands = 3,
    .flags = {},
)

// Tensor operations (GFX1250-specific; no shared parent in defs)
DEF_FORMAT(TENSOR,
    .modifiers = {},
    .unit = TensorUnit,
    .encoding = {64},
    .maxOperands = 2,
    .flags = {TENSORLoadToLds},
)

//==============================================================================
// END OF GFX1250 FORMAT DEFINITIONS
//==============================================================================
