    VCmpxLeI32Inst, "v_cmpx_le_i32", .logical = "VCmpXLeI32",
    VCmpxLeI64Inst, "v_cmpx_le_i64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxLeU16Inst, "v_cmpx_le_u16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxLeU32Inst, "v_cmpx_le_u32", .logical = "VCmpXLeU32",
    VCmpxLeU64Inst, "v_cmpx_le_u64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    // lg
    VCmpxLgF16Inst, "v_cmpx_lg_f16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxLgF32Inst, "v_cmpx_lg_f32",
    VCmpxLgF64Inst, "v_cmpx_lg_f64", .flags = {DPMACC},
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxLgI16Inst, "v_cmpx_lg_i16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxLgI32Inst, "v_cmpx_lg_i32",
    VCmpxLgI64Inst, "v_cmpx_lg_i64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxLgU16Inst, "v_cmpx_lg_u16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxLgU32Inst, "v_cmpx_lg_u32",
    VCmpxLgU64Inst, "v_cmpx_lg_u64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    // lt
    VCmpxLtF16Inst, "v_cmpx_lt_f16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxLtF32Inst, "v_cmpx_lt_f32", .logical = "VCmpXLtF32",
    VCmpxLtF64Inst, "v_cmpx_lt_f64", .flags = {DPMACC},
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxLtI16Inst, "v_cmpx_lt_i16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxLtI32Inst, "v_cmpx_lt_i32", .logical = "VCmpXLtI32",
    VCmpxLtI64Inst, "v_cmpx_lt_i64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxLtU16Inst, "v_cmpx_lt_u16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxLtU32Inst, "v_cmpx_lt_u32", .logical = "VCmpXLtU32",
    VCmpxLtU64Inst, "v_cmpx_lt_u64", .logical = "VCmpXLtU64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    // ne (integer only)
    VCmpxNeI16Inst, "v_cmpx_ne_i16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxNeI32Inst, "v_cmpx_ne_i32",
    VCmpxNeI64Inst, "v_cmpx_ne_i64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxNeU16Inst, "v_cmpx_ne_u16", .logical = "VCmpXNeU16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxNeU32Inst, "v_cmpx_ne_u32", .logical = "VCmpXNeU32",
    VCmpxNeU64Inst, "v_cmpx_ne_u64",
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    // neq, nge, ngt, nle, nlg, nlt (float only)
    VCmpxNeqF16Inst, "v_cmpx_neq_f16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxNeqF32Inst, "v_cmpx_neq_f32",
    VCmpxNeqF64Inst, "v_cmpx_neq_f64", .flags = {DPMACC},
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxNgeF16Inst, "v_cmpx_nge_f16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
    VCmpxNgeF32Inst, "v_cmpx_nge_f32",
    VCmpxNgeF64Inst, "v_cmpx_nge_f64", .flags = {DPMACC},
        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
    VCmpxNgtF16Inst, "v_cmpx_ngt_f16",
        .operand_fields = { {S0, .size=16}, {S1, .size=16} },
