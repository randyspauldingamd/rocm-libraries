        .operand_fields = { {S0, .size=64}, {S1, .size=64} },
)

// Vector Convert (dual VOP1/VOP3 encoding)
DEF_BATCH(.format = VOP1,
    VCvtF16F32Inst, "v_cvt_f16_f32", .logical = "VCvtF32toF16",
        .operand_fields = { {D0, .size=16} },
    VCvtF32Bf16Inst, "v_cvt_f32_bf16", .logical = "PVCvtBF16toFP32",
        .operand_fields = { {S0, .size=16} },
    VCvtF32Bf8Inst, "v_cvt_f32_bf8", .logical = "VCvtBF8toF32",
        .operand_fields = { {S0, .size=8} },
    VCvtF32F16Inst, "v_cvt_f32_f16", .logical = "VCvtF16toF32",
        .operand_fields = { {S0, .size=16} },
    VCvtF32Fp8Inst, "v_cvt_f32_fp8", .logical = "VCvtFP8toF32",
        .operand_fields = { {S0, .size=8} },
    VCvtF32I32Inst, "v_cvt_f32_i32", .logical = "VCvtI32toF32",
    VCvtF32U32Inst, "v_cvt_f32_u32", .logical = "VCvtU32toF32",
    VCvtF64U32Inst, "v_cvt_f64_u32", .logical = "VCvtU32toF64",
        .operand_fields = { {D0, .size=64} },
    VCvtU32F64Inst, "v_cvt_u32_f64", .logical = "VCvtF64toU32", .flags = {DPMACC},
        .operand_fields = { {S0, .size=64} },
    VCvtI32F32Inst, "v_cvt_i32_f32", .logical = "VCvtF32toI32",
    VCvtPkF32Bf8Inst, "v_cvt_pk_f32_bf8", .logical = "VCvtPkBF8toF32",
        .operand_fields = { {D0, .size=64}, {S0, .size=16} },
    VCvtPkF32Fp8Inst, "v_cvt_pk_f32_fp8", .logical = "VCvtPkFP8toF32",
        .operand_fields = { {D0, .size=64}, {S0, .size=16} },
    VCvtU32F32Inst, "v_cvt_u32_f32", .logical = "VCvtF32toU32",
)

// Vector Convert (VOP3-only, 2 sources)
DEF_BATCH(.format = VOP3_2SRC,
    VCvtPkBf16F32Inst, "v_cvt_pk_bf16_f32", .logical = "VCvtPkF32toBF16",
    VCvtPkF16F32Inst, "v_cvt_pk_f16_f32", .logical = "VCvtPkF32toF16",
    VCvtPkBf8F32Inst, "v_cvt_pk_bf8_f32", .logical = "VCvtPkF32toBF8",
        .operand_fields = { {D0, .size=16} },
    VCvtPkFp8F32Inst, "v_cvt_pk_fp8_f32", .logical = "VCvtPkF32toFP8",
        .operand_fields = { {D0, .size=16} },
)

// Vector Convert (VOP3-only, stochastic rounding, D0 is read-write)
DEF_T(VCvtSrBf8F32Inst, "v_cvt_sr_bf8_f32", .logical = "VCvtSRF32toBF8",
    .format = VOP3_2SRC,
    .operand_fields = {
        {D0, vdst, vgpr, 8, RW},
        {S0, src0, src, 32},
        {S1, src1, src, 32},
    },
)
DEF_T(VCvtSrFp8F32Inst, "v_cvt_sr_fp8_f32", .logical = "VCvtSRF32toFP8",
    .format = VOP3_2SRC,
    .operand_fields = {
        {D0, vdst, vgpr, 8, RW},
        {S0, src0, src, 32},
        {S1, src1, src, 32},
    },
)

// Vector Convert with Scale (VOP3-only)
DEF_T(VCvtScalef32Pk8Bf8F16Inst, "v_cvt_scalef32_pk8_bf8_f16",
    .format = VOP3,
    .operand_fields = {
        {D0, vdst, vgpr, 64},
        {S0, src0, src_vgpr, 128},
        {S1, src1, src, 32},
    },
)
DEF_T(VCvtScalef32Pk8Fp8F16Inst, "v_cvt_scalef32_pk8_fp8_f16",
    .format = VOP3,
    .operand_fields = {
        {D0, vdst, vgpr, 64},
        {S0, src0, src_vgpr, 128},
        {S1, src1, src, 32},
    },
)
DEF_T(VCvtScalePk8F16Bf8Inst, "v_cvt_scale_pk8_f16_bf8",
    .format = VOP3,
    .operand_fields = {
        {D0, vdst, vgpr, 128},
        {S0, src0, src_vgpr, 64},
        {S1, src1, src, 32},
    },
)
DEF_T(VCvtScalePk8F16Fp8Inst, "v_cvt_scale_pk8_f16_fp8",
    .format = VOP3,
    .operand_fields = {
        {D0, vdst, vgpr, 128},
        {S0, src0, src_vgpr, 64},
        {S1, src1, src, 32},
    },
)
// Pack-of-8 conversion (8x F32 -> 8x FP8/BF8) with F32 scale.
DEF_T(VCvtScalef32Pk8Fp8F32Inst, "v_cvt_scalef32_pk8_fp8_f32",
    .format = VOP3,
    .operand_fields = {
        {D0, vdst, vgpr, 64},
        {S0, src0, src_vgpr, 256},
        {S1, src1, src, 32},
    },
)
DEF_T(VCvtScalef32Pk8Bf8F32Inst, "v_cvt_scalef32_pk8_bf8_f32",
    .format = VOP3,
    .operand_fields = {
        {D0, vdst, vgpr, 64},
        {S0, src0, src_vgpr, 256},
        {S1, src1, src, 32},
    },
)
// Stochastic-rounding pack-of-8 conversion (8x F32 -> 8x FP8) with F32 scale.
DEF_T(VCvtScalef32SrPk8Fp8F32Inst, "v_cvt_scalef32_sr_pk8_fp8_f32",
    .format = VOP3,
    .operand_fields = {
        {D0, vdst, vgpr, 64},
        {S0, src0, src_vgpr, 256},
        {S1, src1, src, 32},
        {S2, src2, src, 32},
    },
)

// Vector Transcendental — 16/32-bit
DEF_BATCH(.format = VOP1_TRANSCENDENTAL,
    VCosF16Inst, "v_cos_f16",
        .operand_fields = { {D0, .size=16}, {S0, .size=16} },
    VCosF32Inst, "v_cos_f32",
    VExpF16Inst, "v_exp_f16", .logical = "VExpF16",
        .operand_fields = { {D0, .size=16}, {S0, .size=16} },
    VExpF32Inst, "v_exp_f32", .logical = "VExpF32",
    VLogF16Inst, "v_log_f16",
        .operand_fields = { {D0, .size=16}, {S0, .size=16} },
    VLogF32Inst, "v_log_f32",
    VRcpF16Inst, "v_rcp_f16", .logical = "VRcpF16",
        .operand_fields = { {D0, .size=16}, {S0, .size=16} },
    VRcpF32Inst, "v_rcp_f32", .logical = "VRcpF32",
    VRcpIflagF32Inst, "v_rcp_iflag_f32", .logical = "VRcpIFlagF32",
    VRsqF16Inst, "v_rsq_f16", .logical = "VRsqF16",
        .operand_fields = { {D0, .size=16}, {S0, .size=16} },
    VRsqF32Inst, "v_rsq_f32", .logical = "VRsqF32",
    VSinF16Inst, "v_sin_f16",
        .operand_fields = { {D0, .size=16}, {S0, .size=16} },
    VSinF32Inst, "v_sin_f32",
    VSqrtF16Inst, "v_sqrt_f16",
        .operand_fields = { {D0, .size=16}, {S0, .size=16} },
    VSqrtF32Inst, "v_sqrt_f32",
)
// Vector Transcendental — 64-bit
DEF_BATCH(.format = VOP1_TRANSCENDENTAL, .flags = {Trans64},
    VRcpF64Inst, "v_rcp_f64", .logical = "VRcpF64",
        .operand_fields = { {D0, .size=64}, {S0, .size=64} },
    VRsqF64Inst, "v_rsq_f64",
        .operand_fields = { {D0, .size=64}, {S0, .size=64} },
    VSqrtF64Inst, "v_sqrt_f64",
        .operand_fields = { {D0, .size=64}, {S0, .size=64} },
)

//==============================================================================
// REMINDER — Implicit special-register flags for instructions NOT yet defined
//
// When adding any of the following instructions, attach the indicated flags.
// See Flags.def for flag definitions.
//
// ImplicitReadVCC:
//   v_div_fmas_f32, v_div_fmas_f64
//
// ImplicitReadEXEC (does not include VOPs where EXEC solely selects active
// threads):
//   export,
//   s_and_not0_saveexec_b32 (= s_andn1_saveexec_b32),
//   s_and_not0_saveexec_b64 (= s_andn1_saveexec_b64),
//   s_and_not0_wrexec_b32 (= s_andn1_wrexec_b32),
//   s_and_not0_wrexec_b64 (= s_andn1_wrexec_b64),
//   s_and_not1_saveexec_b32 (= s_andn2_saveexec_b32),
//   s_and_not1_saveexec_b64 (= s_andn2_saveexec_b64),
//   s_and_not1_wrexec_b32 (= s_andn2_wrexec_b32),
//   s_and_not1_wrexec_b64 (= s_andn2_wrexec_b64),
//   s_nand_saveexec_b32, s_nand_saveexec_b64,
//   s_nor_saveexec_b32, s_nor_saveexec_b64,
//   s_or_not0_saveexec_b32 (= s_orn1_saveexec_b32),
//   s_or_not0_saveexec_b64 (= s_orn1_saveexec_b64),
//   s_or_not1_saveexec_b32 (= s_orn2_saveexec_b32),
//   s_or_not1_saveexec_b64 (= s_orn2_saveexec_b64),
//   s_xnor_saveexec_b32, s_xnor_saveexec_b64,
//   s_xor_saveexec_b32, s_xor_saveexec_b64
//
// ImplicitWriteEXEC:
//   s_and_not0_saveexec_b32 (= s_andn1_saveexec_b32),
//   s_and_not0_saveexec_b64 (= s_andn1_saveexec_b64),
//   s_and_not0_wrexec_b32 (= s_andn1_wrexec_b32),
//   s_and_not0_wrexec_b64 (= s_andn1_wrexec_b64),
//   s_and_not1_saveexec_b32 (= s_andn2_saveexec_b32),
//   s_and_not1_saveexec_b64 (= s_andn2_saveexec_b64),
//   s_and_not1_wrexec_b32 (= s_andn2_wrexec_b32),
//   s_and_not1_wrexec_b64 (= s_andn2_wrexec_b64),
//   s_nand_saveexec_b32, s_nand_saveexec_b64,
//   s_nor_saveexec_b32, s_nor_saveexec_b64,
//   s_or_not0_saveexec_b32 (= s_orn1_saveexec_b32),
//   s_or_not0_saveexec_b64 (= s_orn1_saveexec_b64),
//   s_or_not1_saveexec_b32 (= s_orn2_saveexec_b32),
//   s_or_not1_saveexec_b64 (= s_orn2_saveexec_b64),
//   s_xnor_saveexec_b32, s_xnor_saveexec_b64,
//   s_xor_saveexec_b32, s_xor_saveexec_b64
//   (All v_cmpx_* instructions also write EXEC — handled via VCMPX format.)
//
// ImplicitReadSCC:
//   s_add_co_ci_u32 (= s_addc_u32, DEFINED), s_cmovk_i32,
//   s_sub_co_ci_u32 (= s_subb_u32, DEFINED)
//
// ImplicitWriteSCC:
//   s_absdiff_i32, s_addk_co_i32 (= s_addk_i32),
//   s_add_co_ci_u32 (= s_addc_u32, DEFINED),
//   s_add_co_i32 (= s_add_i32, DEFINED), s_add_co_u32 (= s_add_u32, DEFINED),
//   s_alloc_vgpr,
//   s_and_not0_saveexec_b32 (= s_andn1_saveexec_b32),
//   s_and_not0_saveexec_b64 (= s_andn1_saveexec_b64),
//   s_and_not0_wrexec_b32 (= s_andn1_wrexec_b32),
//   s_and_not0_wrexec_b64 (= s_andn1_wrexec_b64),
//   s_and_not1_b32 (= s_andn2_b32, DEFINED),
//   s_and_not1_b64 (= s_andn2_b64, DEFINED),
//   s_and_not1_saveexec_b32 (= s_andn2_saveexec_b32),
//   s_and_not1_saveexec_b64 (= s_andn2_saveexec_b64),
//   s_and_not1_wrexec_b32 (= s_andn2_wrexec_b32),
//   s_and_not1_wrexec_b64 (= s_andn2_wrexec_b64),
//   s_barrier_leave, s_barrier_signal_isfirst,
//   s_bcnt0_i32_b32, s_bcnt0_i32_b64, s_bcnt1_i32_b32, s_bcnt1_i32_b64,
//   s_bfe_i32, s_bfe_i64, s_bfe_u32, s_bfe_u64,
//   s_bitcmp0_b32, s_bitcmp0_b64, s_bitcmp1_b64,
//   s_cmp_eq_f16, s_cmp_eq_f32, s_cmp_ge_f16, s_cmp_ge_f32,
//   s_cmp_gt_f16, s_cmp_gt_f32, s_cmp_le_f16, s_cmp_le_f32,
//   s_cmp_lg_f16, s_cmp_lg_f32, s_cmp_lt_f16, s_cmp_lt_f32,
//   s_cmp_neq_f16, s_cmp_neq_f32, s_cmp_nge_f16, s_cmp_nge_f32,
//   s_cmp_ngt_f16, s_cmp_ngt_f32, s_cmp_nle_f16, s_cmp_nle_f32,
//   s_cmp_nlg_f16, s_cmp_nlg_f32, s_cmp_nlt_f16, s_cmp_nlt_f32,
//   s_cmp_o_f16, s_cmp_o_f32, s_cmp_u_f16, s_cmp_u_f32,
//   s_nand_b32, s_nand_b64, s_nand_saveexec_b32, s_nand_saveexec_b64,
//   s_nor_b32, s_nor_b64, s_nor_saveexec_b32, s_nor_saveexec_b64,
//   s_not_b32, s_not_b64,
//   s_or_not0_saveexec_b32 (= s_orn1_saveexec_b32),
//   s_or_not0_saveexec_b64 (= s_orn1_saveexec_b64),
//   s_or_not1_b32 (= s_orn2_b32), s_or_not1_b64 (= s_orn2_b64),
//   s_or_not1_saveexec_b32 (= s_orn2_saveexec_b32),
//   s_or_not1_saveexec_b64 (= s_orn2_saveexec_b64),
//   s_quadmask_b32, s_quadmask_b64,
//   s_sub_co_ci_u32 (= s_subb_u32, DEFINED),
//   s_sub_co_i32 (= s_sub_i32, DEFINED), s_sub_co_u32 (= s_sub_u32, DEFINED),
//   s_wqm_b32, s_wqm_b64,
//   s_xnor_b32, s_xnor_b64, s_xnor_saveexec_b32, s_xnor_saveexec_b64,
//   s_xor_saveexec_b32, s_xor_saveexec_b64
//   (SOPC-format instructions get ImplicitWriteSCC from the format definition.)
//
// Note: The following instructions don't need implicit VCC/EXEC/SCC because
//       they have multiple encoding forms, to distinguish betweens forms,
//       VCC/EXEC/SCC are explicit specified in assembly code.
//
//   v_add_co_ci_u32, v_add_co_u32, v_div_scale_f32, v_div_scale_f64,
//   v_mad_co_i64_i32, v_mad_co_u64_u32,
//   v_subrev_co_ci_u32, v_subrev_co_u32, v_sub_co_ci_u32, v_sub_co_u32
//   v_add_co_ci_u32, v_cndmask_b16, v_cndmask_b32,
//   v_dual_cndmask_b32, v_subrev_co_ci_u32, v_sub_co_ci_u32
//==============================================================================
