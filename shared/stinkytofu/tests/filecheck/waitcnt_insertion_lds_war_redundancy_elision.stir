# RUN: %stinkytofu-opt --arch gfx1250 %s --StinkyBuildImplicitDependencyPass --StinkyWaitCntInsertionPass --print-output
#
# StinkyWaitCntInsertionPass (gfx1250): WAR-on-LDS redundancy elision.
# Two token-0 ds_load_b64 instructions feed a wmma via def-use (RAW), forcing
# the pass to emit s_wait_dscnt 0 before the wmma. A tensor_load_to_lds with
# the same token immediately follows. By the time the WAR check runs at the
# tensor load, dsState.lastEmittedWait is already 0 and opsSinceLastWait is 0,
# so needsNewWait(0) returns false -- the existing wait already covers the
# WAR hazard and no extra waitcnt is emitted.
#
# CHECK-LABEL: @waitcnt_insertion_lds_war_redundancy_elision
# CHECK: ds_load_b64
# CHECK-NEXT: ds_load_b64
# CHECK-NEXT: s_wait_dscnt
# CHECK-SAME: dlcnt = 0
# CHECK-NEXT: v_wmma_f32_16x16x32_bf16
# CHECK-NEXT: tensor_load_to_lds
# CHECK-NOT: s_wait_loadcnt
# CHECK-NOT: s_wait_tensorcnt

st.func @waitcnt_insertion_lds_war_redundancy_elision() {
^entry:
  v[0:1] = "st.ds_load_b64"(v10) { mod.ds = { na = 1, offset = 0, gds = false }, mod.memtoken = { tokens = [0] } }
  v[2:3] = "st.ds_load_b64"(v10) { mod.ds = { na = 1, offset = 16, gds = false }, mod.memtoken = { tokens = [0] } }
  a[10:17] = "st.v_wmma_f32_16x16x32_bf16"(v[0:7], v[0:7], a[10:17]) { mod.mfma = { reuseA = false, reuseB = false } }
  "st.tensor_load_to_lds"(s[0:3], s[10:17]) { mod.memtoken = { tokens = [0] } }
}
