# RUN: %stinkytofu-opt --arch gfx1250 %s --StinkyBuildImplicitDependencyPass --StinkyDAGSchedulerPass --print-output
#
# DS read reordering: AAAAB → BAAAA.
# 2 ds_loads per operand (filling 8-wide WMMA operands).
# B0 is shared by all 4 WMMAs. A0-A3 each feed one WMMA.
# Only the first affinity group (WMMA0) is mixed (A0+B0).
# Groups 1-3 are A-only → look-ahead puts B first in group 0.
# Result: B0B0, A0A0, A1A1, A2A2, A3A3.
#
# B0 loads first (shared operand, look-ahead sees A-only groups)
# CHECK: v[50:53]{{.*}}ds_load_b128
# CHECK: v[54:57]{{.*}}ds_load_b128
# Then A0 loads (WMMAs may interleave after latency decays)
# CHECK: v[8:11]{{.*}}ds_load_b128
# CHECK: v[12:15]{{.*}}ds_load_b128

st.func @test() {
^entry:
  v[8:11] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 0, gds = false }, mod.memtoken = { tokens = [0] } }
  v[12:15] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 32, gds = false }, mod.memtoken = { tokens = [0] } }
  v[16:19] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 8192, gds = false }, mod.memtoken = { tokens = [0] } }
  v[20:23] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 8224, gds = false }, mod.memtoken = { tokens = [0] } }
  v[24:27] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 16384, gds = false }, mod.memtoken = { tokens = [0] } }
  v[28:31] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 16416, gds = false }, mod.memtoken = { tokens = [0] } }
  v[32:35] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 24576, gds = false }, mod.memtoken = { tokens = [0] } }
  v[36:39] = "st.ds_load_b128"(v100) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 24608, gds = false }, mod.memtoken = { tokens = [0] } }
  v[50:53] = "st.ds_load_b128"(v101) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 0, gds = false }, mod.memtoken = { tokens = [0] } }
  v[54:57] = "st.ds_load_b128"(v101) { issueCycles = 1, latencyCycles = 56, mod.ds = { na = 1, offset = 32, gds = false }, mod.memtoken = { tokens = [0] } }
  v[0:7] = "st.v_wmma_f32_16x16x16_bf16"(v[8:15], v[50:57], v[0:7]) { mod.mfma = { reuseA = false, reuseB = false } }
  v[0:7] = "st.v_wmma_f32_16x16x16_bf16"(v[16:23], v[50:57], v[0:7]) { mod.mfma = { reuseA = false, reuseB = false } }
  v[0:7] = "st.v_wmma_f32_16x16x16_bf16"(v[24:31], v[50:57], v[0:7]) { mod.mfma = { reuseA = false, reuseB = false } }
  v[0:7] = "st.v_wmma_f32_16x16x16_bf16"(v[32:39], v[50:57], v[0:7]) { mod.mfma = { reuseA = false, reuseB = false } }
}
