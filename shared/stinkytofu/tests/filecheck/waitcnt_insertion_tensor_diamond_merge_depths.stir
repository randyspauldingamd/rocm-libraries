# RUN: %stinkytofu-opt --arch gfx1250 %s --StinkyBuildImplicitDependencyPass --StinkyWaitCntInsertionPass --print-output
#
# Policy
# ------
# A tensor-wait anchor at a merge block must drain its conflicting
# tensor_load_to_lds dep on EVERY incoming CFG path. Each incoming path
# carries its own per-path tensor-load FIFO -- the tensor_load_to_lds ops
# issued on that path that are still in flight at the merge entry.
#
# CFG (tensor ops shown; cbranch is s_cbranch_scc1 to ^p_shallow when SCC0 set):
#
#                         ^entry
#                    tensor_load [11]
#                        /     \
#           (taken)     /       \     (fall-through)
#                     v           v
#               ^p_shallow     ^p_deep
#              (no extra ops)  tensor_load [12]
#                     \         tensor_load [12]
#                      \       /
#                       v     v
#                      ^merge
#                   s_barrier [11]
#                   s_barrier [12]
#
# Per-path tensor FIFO at the merge anchor (drain token [11]):
#   via ^p_shallow: [t11]                 -> shallow (1 in flight) -> tlcnt=0
#   via ^p_deep:    [t11], [t12], [t12]   -> deep    (3 in flight) -> tlcnt=2
#
# Per-path tensor FIFO at the second barrier (drain token [12]):
#   via ^p_shallow: (empty after first barrier) -> unconstrained
#   via ^p_deep:    [t12], [t12]          -> tlcnt=0
#
# A single merge anchor wait sized for the deeper predecessor (^p_deep,
# tlcnt=2) is a no-op on ^p_shallow, so the shared t11 dep would not drain
# on the shallow path. The pass PROMOTES the conservative full drain out of
# the merge into ^p_shallow's tail, then relaxes the merge wait to ^p_deep's
# depth (still correct on ^p_shallow, which already drained at its own tail).
#
# The shared t11 must be issued in ^entry (before the split), not only in
# ^p_shallow: with the load only in ^p_shallow the planner collapses paths
# and emits tlcnt=0 at the merge. An explicit cbranch is required (entry
# "Successors: ^a, ^b" without a branch does not split per-path FIFO state).
#
# CHECK-LABEL: @waitcnt_insertion_tensor_diamond_merge_depths
#
# Entry issues the shared tensor load whose dep flows to both branches.
# CHECK: ^entry
# CHECK: tensor_load_to_lds{{.*}}tokens = [11]
# CHECK: s_cbranch_scc1
#
# ^p_deep (deep predecessor): two extra tensor_load_to_lds with a disjoint
# token that extend its in-flight depth ahead of the merge. No pre-drain
# inserted here because ^p_deep's depth drives the merge wait.
# CHECK: ^p_deep
# CHECK: tensor_load_to_lds{{.*}}tokens = [12]
# CHECK-NEXT: tensor_load_to_lds{{.*}}tokens = [12]
# CHECK-NOT: s_wait_tensorcnt
#
# ^p_shallow (shallow predecessor): receives the promoted
# `s_wait_tensorcnt 0` so the shared dep is drained on this path before
# reaching the merge.
# CHECK: ^p_shallow
# CHECK: s_wait_tensorcnt{{.*}}tlcnt = 0
#
# ^merge: relaxed wait sized for ^p_deep's depth, emitted before the barrier
# that conflicts with the shared dep on token 11; then a full drain before
# the barrier on the disjoint token 12.
# CHECK: ^merge
# CHECK: s_wait_tensorcnt{{.*}}tlcnt = 2
# CHECK-NEXT: s_barrier{{.*}}tokens = [11]
# CHECK-NEXT: s_wait_tensorcnt{{.*}}tlcnt = 0
# CHECK-NEXT: s_barrier{{.*}}tokens = [12]

st.func @waitcnt_insertion_tensor_diamond_merge_depths() {
^entry:
  "st.tensor_load_to_lds"(s[0:3], s[10:17]) { mod.memtoken = { tokens = [11] } }
  SCC0 = "st.s_cmp_eq_u32"(s13, 0x1)
  "st.s_cbranch_scc1"("p_shallow", SCC0)
  Successors: ^p_shallow, ^p_deep
^p_deep:
  "st.tensor_load_to_lds"(s[4:7], s[18:25]) { mod.memtoken = { tokens = [12] } }
  "st.tensor_load_to_lds"(s[8:11], s[26:33]) { mod.memtoken = { tokens = [12] } }
  Successors: ^merge
^p_shallow:
  Successors: ^merge
^merge:
  "st.s_barrier"() { mod.memtoken = { tokens = [11] } }
  "st.s_barrier"() { mod.memtoken = { tokens = [12] } }
}
