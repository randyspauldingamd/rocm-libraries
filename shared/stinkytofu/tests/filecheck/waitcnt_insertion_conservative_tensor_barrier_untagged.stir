# RUN: %stinkytofu-opt --arch gfx1250 %s --StinkyWaitCntInsertionPass --print-output
#
# StinkyWaitCntInsertionPass (gfx1250): conservative fallback at the
# tensor-barrier matching site (Site C) when the barrier itself is
# missing its MemTokenData modifier.
#
# IR (single block):
#   tensor_load_to_lds   tokens=[1]    (T0)
#   tensor_load_to_lds   tokens=[2]    (T1)
#   s_barrier            (NO MemTokenData)
#
# reinsertTensorWaitsHeuristic pushes both tensor loads into the deque
# (token presence does not gate insertion under the fallback). When it
# reaches the untagged s_barrier, the anchor-missing-tokens branch fires:
#   - Emit s_wait_tensorcnt 0 immediately before the barrier
#   - Clear the tensorLoads deque
#
# CHECK-LABEL: @waitcnt_insertion_conservative_tensor_barrier_untagged
# Both tensor loads are emitted back-to-back without any intervening wait.
# CHECK: tensor_load_to_lds
# CHECK-SAME: tokens = [1]
# CHECK-NEXT: tensor_load_to_lds
# CHECK-SAME: tokens = [2]
# Conservative drain of the entire tensor counter before the untagged barrier.
# CHECK-NEXT: s_wait_tensorcnt
# CHECK-SAME: tlcnt = 0
# CHECK-NEXT: s_barrier
# CHECK-NOT: s_wait_tensorcnt
# CHECK-NOT: s_wait_dscnt
# CHECK-NOT: s_wait_loadcnt

st.func @waitcnt_insertion_conservative_tensor_barrier_untagged() {
^entry:
  "st.tensor_load_to_lds"(s[0:3], s[10:17]) { issueCycles = 1, latencyCycles = 1, mod.memtoken = { tokens = [1] } }
  "st.tensor_load_to_lds"(s[4:7], s[18:25]) { issueCycles = 1, latencyCycles = 1, mod.memtoken = { tokens = [2] } }
  "st.s_barrier"() { issueCycles = 1, latencyCycles = 1 }
}
