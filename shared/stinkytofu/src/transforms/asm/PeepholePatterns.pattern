//===- PeepholePatterns.pattern - Peephole optimization patterns -----------===//
//
// StinkyTofu GPU Compiler Library
//
// Declarative pattern definitions for peephole optimizations.
// Parsed at compile time by TableGen, generates C++ matcher code.
//
// Original Python implementations: projects/hipblaslt/tensilelite/Tensile/Activation.py
//
//===----------------------------------------------------------------------===//

//===----------------------------------------------------------------------===//
// Pattern 1: Add+FMA Fusion (F32)
//
// Fuses a v_add_f32 into a preceding v_fma_f32 by folding constants.
// Handles both in-place and non-in-place additions.
//
// Example (in-place):
//   v_fma_f32 v0, a, b, 1.0
//   v_add_f32 v0, 1.0, v0
//   => v_fma_f32 v0, a, b, 2.0
//
// Example (non-in-place):
//   v_fma_f32 v0, a, b, 1.0
//   v_add_f32 v2, 1.0, v0
//   => v_fma_f32 v2, a, b, 2.0  (v0 eliminated!)
//
// Requirements:
//   - FMA result has only ONE use (the ADD)
//   - Both FMA and ADD have constant addends
//
// Benefit: 2 instructions → 1, constant folding, may free register
//
// Original: Activation.py lines 1016-1050
//===----------------------------------------------------------------------===//

peephole pattern AddFMAFusion_F32 {
  match {
    // First: FMA produces $fma_result
    $fma_inst = v_fma_f32 $fma_result, $a, $b, $fma_const

    // Second: ADD uses $fma_result
    $add_inst = v_add_f32 $add_dst, $add_const, $fma_result
  }

  constraints {
    HasOneUse($fma_result)    // FMA result only used by this ADD
    IsConstant($fma_const)    // FMA has constant addend
    IsConstant($add_const)    // ADD has constant addend
  }

  rewrite {
    // Fold constants: $fma_const + $add_const
    $new_const = AddConstants($fma_const, $add_const)

    // Create new FMA with ADD's destination and folded constant
    $new_fma = v_fma_f32 $add_dst, $a, $b, $new_const

    // Replace old FMA, remove ADD
    replace $fma_inst with $new_fma
    remove $add_inst
  }
}

//===----------------------------------------------------------------------===//
// Pattern 2: Add+FMA Fusion (F16)
//
// Same as F32 variant, but for half-precision floats.
//===----------------------------------------------------------------------===//

peephole pattern AddFMAFusion_F16 {
  match {
    $fma_inst = v_fma_f16 $fma_result, $a, $b, $fma_const
    $add_inst = v_add_f16 $add_dst, $add_const, $fma_result
  }

  constraints {
    HasOneUse($fma_result)
    IsConstant($fma_const)
    IsConstant($add_const)
  }

  rewrite {
    $new_const = AddConstants($fma_const, $add_const)
    $new_fma = v_fma_f16 $add_dst, $a, $b, $new_const
    replace $fma_inst with $new_fma
    remove $add_inst
  }
}

