    "gfx90a": {
      "_comment": "CDNA2 (MI200 / Aldebaran). Wave64, 64 KB LDS. No fp8/bf8 native MFMA (those arrived with gfx940/gfx942). No async_lds. bf16 32x32x8 is hardware-verified on MI200 series. Hardware-verified MMA set matches AMD ISA manual v3 (GFX9 MFMA section).",
      "family": "cdna",
      "target_family": "gfx9_mfma",
      "wave_size": 64,
      "lds_capacity_bytes": 65536,
      "vmcnt_bits": 4,
      "memory": {
        "has_async_lds": false,
        "has_ds_read_tr": false,
        "buffer_load_max_dwords": 4
      },
      "limits": {
        "max_threads_per_block": 1024,
