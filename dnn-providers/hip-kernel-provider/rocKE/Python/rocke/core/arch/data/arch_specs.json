    "gfx1151": {
      "_comment": "RDNA3.5 (Strix Halo APU). WAVE32, WMMA not MFMA. Datalayout/triple identical to CDNA on this ROCm (clang-verified on ctr-halo). WMMA f16/bf16 16x16x16 ABI hardware-verified: llvm.amdgcn.wmma.f32.16x16x16.f16.v8f32.v16f16(<16 x half>,<16 x half>,<8 x float>)->-<8 x float>; A frag lane l=row l%16 (K=0..15), B frag lane l=col l%16 (K=0..15), D lane l slot i=(row 2i+l/16, col l%16).",
      "family": "rdna",
      "target_family": "gfx11_rdna",
      "wave_size": 32,
      "lds_capacity_bytes": 65536,
      "vmcnt_bits": 6,
      "memory": {
        "has_async_lds": false,
        "has_ds_read_tr": false,
        "buffer_load_max_dwords": 4
      },
      "limits": {
        "max_threads_per_block": 1024,
        "vgprs": 256,
        "agprs": 0,
        "sgprs": 106
      },
      "mma": [
        {"family": "wmma", "a": "fp16", "b": "fp16", "c": "fp32", "m": 16, "n": 16, "k": 16, "op_id": "wmma_f32_16x16x16_f16"},
        {"family": "wmma", "a": "bf16", "b": "bf16", "c": "fp32", "m": 16, "n": 16, "k": 16, "op_id": "wmma_f32_16x16x16_bf16"},
