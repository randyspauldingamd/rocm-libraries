@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(hip CONFIG REQUIRED)

# Find required dependencies
find_package(Threads REQUIRED)

# Export HIPDNN_FRONTEND_SKIP_JSON_LIB setting for consumers
set(HIPDNN_FRONTEND_SKIP_JSON_LIB @HIPDNN_FRONTEND_SKIP_JSON_LIB@ CACHE BOOL
    "Defines whether FE should not include nlohmann/json.hpp.")

# nlohmann_json is optional based on HIPDNN_FRONTEND_SKIP_JSON_LIB
if(NOT HIPDNN_FRONTEND_SKIP_JSON_LIB)
    find_dependency(nlohmann_json REQUIRED)
endif()

# Subdirectory path for hipDNN engine plugins (relative to lib)
set(HIPDNN_PLUGIN_ENGINE_SUBDIR "@HIPDNN_PLUGIN_ENGINE_SUBDIR@")

# Full install path for engine plugins (relocatable using PACKAGE_ prefix from configure_package_config_file)
set(HIPDNN_FULL_INSTALL_PLUGIN_ENGINE_DIR "@PACKAGE_HIPDNN_FULL_INSTALL_PLUGIN_ENGINE_DIR@")
set(HIPDNN_RELATIVE_INSTALL_PLUGIN_ENGINE_DIR "@HIPDNN_RELATIVE_INSTALL_PLUGIN_ENGINE_DIR@")

# Local should assume flatbuffer is the primary flatbuffer version during configure and build.
set(flatbuffers_VERSION "@HIPDNN_FLATBUFFERS_VERSION@")

# Validate FlatBuffers version is supported by this build of hipdnn_data_sdk
set(_hipdnn_supported_flatbuffers_versions "@HIPDNN_SUPPORTED_FLATBUFFERS_VERSIONS@")
if(flatbuffers_VERSION AND NOT flatbuffers_VERSION IN_LIST _hipdnn_supported_flatbuffers_versions)
    message(FATAL_ERROR
        "hipDNN Data SDK: Unsupported FlatBuffers version: ${flatbuffers_VERSION}. "
        "Supported versions are: ${_hipdnn_supported_flatbuffers_versions}"
    )
endif()

include("${CMAKE_CURRENT_LIST_DIR}/hipdnn_data_sdkTargets.cmake")

# Add the correct versioned generated headers to the include path based on detected FlatBuffers version
if(flatbuffers_VERSION)
    string(REPLACE "." "_" _hipdnn_fb_version_tag "${flatbuffers_VERSION}")
    cmake_path(SET _hipdnn_sdk_prefix NORMALIZE "${CMAKE_CURRENT_LIST_DIR}/../../../")
    # Prepend versioned headers to ensure they're found first
    get_property(_existing_includes TARGET hipdnn_data_sdk PROPERTY INTERFACE_INCLUDE_DIRECTORIES)
    list(PREPEND _existing_includes
        "${_hipdnn_sdk_prefix}/@HIP_DNN_DATA_SDK_INSTALL_INCLUDE_DIR@/hipdnn_data_sdk/data_objects/v${_hipdnn_fb_version_tag}")
    set_property(TARGET hipdnn_data_sdk PROPERTY INTERFACE_INCLUDE_DIRECTORIES ${_existing_includes})
    message(STATUS "hipDNN Data SDK: Using local FlatBuffers ${flatbuffers_VERSION} headers (v${_hipdnn_fb_version_tag})")
endif()

message(STATUS "hipDNN Data SDK: Engine plugin build directory is ${CMAKE_INSTALL_LIBDIR}/${HIPDNN_PLUGIN_ENGINE_SUBDIR}")
message(STATUS "hipDNN Data SDK: Plugin absolute installation directory ${HIPDNN_FULL_INSTALL_PLUGIN_ENGINE_DIR}")
message(STATUS "hipDNN Data SDK: Plugin relative installation directory ${HIPDNN_RELATIVE_INSTALL_PLUGIN_ENGINE_DIR}")
