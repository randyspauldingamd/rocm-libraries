include "knob_value.fbs";

namespace hipdnn_data_sdk.data_objects;

table KnobSetting {
    knob_id: int64;
    value: KnobValue;
}

table EngineConfig {
    engine_id: int64;
    knobs: [KnobSetting];
}

root_type EngineConfig;
