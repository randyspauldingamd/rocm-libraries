@PACKAGE_INIT@

# Include the SDK config file to get plugin-related variables
include(CMakeFindDependencyMacro)
find_dependency(hipdnn_sdk CONFIG REQUIRED)
find_dependency(hipdnn_backend CONFIG REQUIRED)

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/hipdnn_frontendTargets.cmake")

# Forward the SDK variables for convenience (if frontend is only included)
set(HIPDNN_PLUGIN_ENGINE_SUBDIR "${HIPDNN_PLUGIN_ENGINE_SUBDIR}")
set(HIPDNN_INSTALL_PLUGIN_ENGINE_DIR "${HIPDNN_INSTALL_PLUGIN_ENGINE_DIR}")

check_required_components(hipdnn_frontend)
