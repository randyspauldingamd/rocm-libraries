{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-samples",
      "hidden": true,
      "displayName": "Base samples build settings",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Samples Configuration",
      "inherits": ["base-samples"],
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "${sourceDir}/../build/debug/lib/cmake"
      }
    },
    {
      "name": "release",
      "displayName": "Release Samples Configuration",
      "inherits": ["base-samples"],
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "${sourceDir}/../build/release/lib/cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug Samples Build",
      "configurePreset": "debug",
      "jobs": 8,
      "targets": ["all"]
    },
    {
      "name": "release",
      "displayName": "Release Samples Build",
      "configurePreset": "release",
      "jobs": 8,
      "targets": ["all"]
    }
  ],
  "workflowPresets": [
    {
      "name": "debug",
      "displayName": "Configure and Build (Debug)",
      "steps": [
        {
          "type": "configure",
          "name": "debug"
        },
        {
          "type": "build",
          "name": "debug"
        }
      ]
    },
    {
      "name": "release",
      "displayName": "Configure and Build (Release)",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        }
      ]
    }
  ]
}
