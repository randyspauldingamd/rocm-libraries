{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-hipdnn",
      "hidden": true,
      "displayName": "Base hipdnn library build settings",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Build Configuration with Install Prefix Set To Bin Dir",
      "inherits": ["base-hipdnn"],
      "binaryDir": "${sourceDir}/build/debug",
      "installDir": "${sourceDir}/build/debug/installdir",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/debug/installdir"
      }
    },
    {
      "name": "release",
      "displayName": "Release Build Configuration with Install Prefix Set To Bin Dir",
      "inherits": ["base-hipdnn"],
      "binaryDir": "${sourceDir}/build/release",
      "installDir": "${sourceDir}/build/release/installdir",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/release/installdir"
      }
    },
    {
      "name": "debug-default-install",
      "displayName": "Debug Build Configuration",
      "inherits": ["base-hipdnn"],
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-default-install",
      "displayName": "Release Build Configuration",
      "inherits": ["base-hipdnn"],
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "targets": ["all"]
    },
    {
      "name": "release",
      "configurePreset": "release",
      "targets": ["all"]
    },
    {
      "name": "install-debug",
      "configurePreset": "debug",
      "targets": ["install"]
    },
    {
      "name": "install-release",
      "configurePreset": "release",
      "targets": ["install"]
    },
    {
      "name": "install-debug-default",
      "configurePreset": "debug-default-install",
      "targets": ["install"]
    },
    {
      "name": "install-release-default",
      "configurePreset": "release-default-install",
      "targets": ["install"]
    }
  ],
  "testPresets": [
    {
      "name": "base-test",
      "displayName": "Run All Tests (Debug)",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "test-all-debug",
      "displayName": "Run All Tests (Debug)",
      "configurePreset": "debug",
      "inherits": ["base-test"]
    },
    {
      "name": "test-all-release",
      "displayName": "Run All Tests (Release)",
      "configurePreset": "release",
      "inherits": ["base-test"]
    },
    {
      "name": "test-unit-debug-parallel",
      "displayName": "Run All Unit Tests in Parallel (Debug)",
      "configurePreset": "debug",
      "inherits": ["base-test"],
      "filter": {
        "include": {
          "name": "hipdnn_backend_tests|hipdnn_data_sdk_tests|hipdnn_frontend_tests|hipdnn_plugin_sdk_tests|miopen_plugin_tests|hipdnn_test_sdk_tests"
        }
      },
      "execution": {
        "jobs": 8
      }
    },
    {
      "name": "test-unit-release-parallel",
      "displayName": "Run All Unit Tests in Parallel (Release)",
      "configurePreset": "release",
      "inherits": ["base-test"],
      "filter": {
        "include": {
          "name": "hipdnn_backend_tests|hipdnn_data_sdk_tests|hipdnn_frontend_tests|hipdnn_plugin_sdk_tests|miopen_plugin_tests|hipdnn_test_sdk_tests"
        }
      },
      "execution": {
        "jobs": 8
      }
    },
    {
      "name": "test-integration-debug",
      "displayName": "Run All Integration Tests (Debug)",
      "configurePreset": "debug",
      "inherits": ["base-test"],
      "filter": {
        "include": {
          "name": "hipdnn_public_backend_tests|hipdnn_public_frontend_tests|miopen_plugin_integration_test"
        }
      }
    },
    {
      "name": "test-integration-release",
      "displayName": "Run All Integration Tests (Release)",
      "configurePreset": "release",
      "inherits": ["base-test"],
      "filter": {
        "include": {
          "name": "hipdnn_public_backend_tests|hipdnn_public_frontend_tests|miopen_plugin_integration_test"
        }
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "debug",
      "displayName": "Configure and Build (Debug)",
      "steps": [
        {
          "type": "configure",
          "name": "debug"
        },
        {
          "type": "build",
          "name": "debug"
        }
      ]
    },
    {
      "name": "release",
      "displayName": "Configure and Build (Release)",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        }
      ]
    },
    {
      "name": "debug-test",
      "displayName": "Configure, Build, and Test (Debug)",
      "steps": [
        {
          "type": "configure",
          "name": "debug"
        },
        {
          "type": "build",
          "name": "debug"
        },
        {
          "type": "test",
          "name": "test-all-debug"
        }
      ]
    },
    {
      "name": "release-test",
      "displayName": "Configure, Build, and Test (Release)",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        },
        {
          "type": "test",
          "name": "test-all-release"
        }
      ]
    }
  ]
}
