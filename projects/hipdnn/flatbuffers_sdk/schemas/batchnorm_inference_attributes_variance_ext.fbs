namespace hipdnn_flatbuffers_sdk.data_objects;

// Note
// This is an additional version of batchnorm inference that uses a variance tensor
// instead of inv_variance tensor.

// The long attributes are keys to the tensor_attributes->uid
table BatchnormInferenceAttributesVarianceExt {
    x_tensor_uid: long;
    mean_tensor_uid: long;
    variance_tensor_uid: long;
    scale_tensor_uid: long;
    bias_tensor_uid: long;
    y_tensor_uid: long;
    epsilon_tensor_uid: long;
}
