# Disable bugprone-unchecked-optional-access in test code because clang-tidy's
# flow analysis does not recognise gtest ASSERT_TRUE(opt.has_value()) as a
# guard, producing only false positives in test files.
InheritParentConfig: true
Checks: >
  -bugprone-unchecked-optional-access
