@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(flatbuffers REQUIRED)
find_dependency(spdlog REQUIRED)
find_dependency(nlohmann_json REQUIRED)

# Subdirectory path for hipDNN engine plugins (relative to lib)
set(HIPDNN_PLUGIN_ENGINE_SUBDIR "@HIPDNN_PLUGIN_ENGINE_SUBDIR@")

# Install directory for hipDNN engine plugins (relative to CMAKE_INSTALL_PREFIX)
set(HIPDNN_INSTALL_PLUGIN_ENGINE_DIR "@HIPDNN_INSTALL_PLUGIN_ENGINE_DIR@")

# Full install path for engine plugins
set(HIPDNN_PLUGIN_ENGINE_INSTALL_PATH "${CMAKE_INSTALL_PREFIX}/@HIPDNN_INSTALL_PLUGIN_ENGINE_DIR@")

include("${CMAKE_CURRENT_LIST_DIR}/hipdnn_sdkTargets.cmake")

message(STATUS "hipDNN SDK: Engine plugin build directory is lib/${HIPDNN_PLUGIN_ENGINE_SUBDIR}")
message(STATUS "hipDNN SDK: Plugin installation directory is ${HIPDNN_PLUGIN_ENGINE_INSTALL_PATH}")
