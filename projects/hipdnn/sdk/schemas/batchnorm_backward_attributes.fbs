namespace hipdnn.sdk;

table BatchNormBackwardAttributes {
    dy: long;
    x: long;
    mean: long = null;
    inv_variance: long = null;
    scale: long;
    peer_stats: [long];
    dx: long;
    dscale: long;
    dbias: long;
}