{% set sdk_ns = df.cpp_enum.rsplit('::', 1)[0] %}
{% set sdk_type = df.enum_short_type %}
{% set fe_type = df.effective_frontend_type %}
{% set sentinel_values = df.enum_def.values | selectattr('sentinel') | list %}
{% set has_sentinel = sentinel_values | length > 0 %}
{% set first_sentinel = sentinel_values[0] if has_sentinel else None %}
# ============================================================
# Target: frontend/include/hipdnn_frontend/Types.hpp
# — Frontend enum class
# ============================================================

enum class {{ fe_type }}
{
{% if has_sentinel %}
    NOT_SET = 0, ///< Mode not specified
{% endif %}
{% for v in df.enum_def.non_sentinel_values %}
{% if v.description %}
{% if not loop.last %}
    {{ v.effective_frontend_name }} = {{ v.effective_frontend_value }}, ///< {{ v.description }}
{% else %}
    {{ v.effective_frontend_name }} = {{ v.effective_frontend_value }} ///< {{ v.description }}
{% endif %}
{% else %}
{% if not loop.last %}
    {{ v.effective_frontend_name }} = {{ v.effective_frontend_value }},
{% else %}
    {{ v.effective_frontend_name }} = {{ v.effective_frontend_value }}
{% endif %}
{% endif %}
{% endfor %}
};

# ============================================================
# Target: frontend/include/hipdnn_frontend/Types.hpp
# — toBackend converter (frontend -> backend C-API)
# ============================================================

inline std::optional<{{ df.test_c_type }}> {{ df.backend_converter }}(const {{ fe_type }}& type)
{
    switch(type)
    {
{% for v in df.enum_def.non_sentinel_values %}
    case {{ fe_type }}::{{ v.effective_frontend_name }}:
        return {{ df.enum_def.backend_prefix }}{{ v.name }};
{% endfor %}
    default:
        return std::nullopt;
    }
}

# ============================================================
# Target: frontend/include/hipdnn_frontend/Types.hpp
# — fromHipdnn converter (backend C-API -> frontend)
# ============================================================

inline std::pair<{{ fe_type }}, Error> {{ df.frontend_inverse_converter }}({{ df.test_c_type }} mode)
{
    switch(mode)
    {
{% for v in df.enum_def.non_sentinel_values %}
    case {{ df.enum_def.backend_prefix }}{{ v.name }}:
        return {{ '{' }}{{ fe_type }}::{{ v.effective_frontend_name }}, {}{{ '}' }};
{% endfor %}
    default:
{% if has_sentinel %}
        return {{ '{' }}{{ fe_type }}::NOT_SET,
                {ErrorCode::HIPDNN_BACKEND_ERROR,
                 "Unknown {{ df.test_c_type }} value: " + std::to_string(static_cast<int>(mode))}{{ '}' }};
{% else %}
{% set first_value = df.enum_def.non_sentinel_values[0] %}
        return {{ '{' }}{{ fe_type }}::{{ first_value.effective_frontend_name }},
                {ErrorCode::HIPDNN_BACKEND_ERROR,
                 "Unknown {{ df.test_c_type }} value: " + std::to_string(static_cast<int>(mode))}{{ '}' }};
{% endif %}
    }
}
