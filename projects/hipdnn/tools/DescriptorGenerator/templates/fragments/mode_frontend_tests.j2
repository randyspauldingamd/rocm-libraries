{% set fe_type = df.effective_frontend_type %}
{% set non_sentinel = df.enum_def.non_sentinel_values %}
# ============================================================
# Target: frontend/tests/TestTypes.cpp
# — {{ df.frontend_inverse_converter }} converter tests
# ============================================================

TEST(TestTypes, FromHipdnn{{ fe_type }}AllValidModes)
{
    using namespace hipdnn_frontend;

    std::vector<std::pair<{{ df.test_c_type }}, {{ fe_type }}>> const validModes = {
{% for v in non_sentinel %}
        {{ '{' }}{{ df.enum_def.backend_prefix }}{{ v.name }}, {{ fe_type }}::{{ v.effective_frontend_name }}{{ '}' }},
{% endfor %}
    };

    for(const auto& [hipdnnMode, expectedMode] : validModes)
    {
        auto [mode, err] = {{ df.frontend_inverse_converter }}(hipdnnMode);
        EXPECT_TRUE(err.is_good())
            << "{{ df.frontend_inverse_converter }} failed for mode value "
            << static_cast<int>(hipdnnMode);
        EXPECT_EQ(mode, expectedMode)
            << "Mismatch for mode value " << static_cast<int>(hipdnnMode);
    }
}

TEST(TestTypes, FromHipdnn{{ fe_type }}UnknownReturnsError)
{
    using namespace hipdnn_frontend;

    auto unknownMode = static_cast<{{ df.test_c_type }}>(9999);
    auto [mode, err] = {{ df.frontend_inverse_converter }}(unknownMode);
    EXPECT_TRUE(err.is_bad());
    EXPECT_EQ(err.code, ErrorCode::HIPDNN_BACKEND_ERROR);
{% set sentinel_values = df.enum_def.values | selectattr('sentinel') | list %}
{% if sentinel_values | length > 0 %}
    EXPECT_EQ(mode, {{ fe_type }}::NOT_SET);
{% endif %}
    EXPECT_TRUE(err.get_message().find("Unknown") != std::string::npos);
}

TEST(TestTypes, FromHipdnn{{ fe_type }}RoundTrip)
{
    using namespace hipdnn_frontend;

    for(auto mode : {
{% for v in non_sentinel %}
            {{ fe_type }}::{{ v.effective_frontend_name }},
{% endfor %}
        })
    {
        auto hipdnnOpt = {{ df.backend_converter }}(mode);
        ASSERT_TRUE(hipdnnOpt.has_value())
            << "{{ df.backend_converter }} failed for mode "
            << static_cast<int>(mode);
        auto [roundTripped, err] = {{ df.frontend_inverse_converter }}(hipdnnOpt.value());
        EXPECT_TRUE(err.is_good())
            << "{{ df.frontend_inverse_converter }} failed for mode "
            << static_cast<int>(mode);
        EXPECT_EQ(roundTripped, mode)
            << "Round-trip mismatch for mode " << static_cast<int>(mode);
    }
}
