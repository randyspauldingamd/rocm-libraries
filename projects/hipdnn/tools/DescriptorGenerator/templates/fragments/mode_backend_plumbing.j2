{{ df.cpp_enum }} toSdk{{ sdk_type }}({{ df.test_c_type }} mode)
{
    using {{ sdk_ns }}::{{ sdk_type }};

    switch(mode)
    {
{% for v in df.enum_def.non_sentinel_values %}
    case {{ df.enum_def.backend_prefix }}{{ v.name }}:
        return {{ sdk_type }}::{{ v.effective_sdk_name }};
{% endfor %}
    default:
        throw HipdnnException(HIPDNN_STATUS_BAD_PARAM, "Unsupported {{ df.test_c_type }} value");
    }
}

{{ df.test_c_type }} fromSdk{{ sdk_type }}({{ df.cpp_enum }} mode)
{
    using {{ sdk_ns }}::{{ sdk_type }};

    switch(mode)
    {
{% for v in df.enum_def.non_sentinel_values %}
    case {{ sdk_type }}::{{ v.effective_sdk_name }}:
        return {{ df.enum_def.backend_prefix }}{{ v.name }};
{% endfor %}
    default:
        throw HipdnnException(HIPDNN_STATUS_BAD_PARAM, "Unsupported SDK {{ sdk_type }} value");
    }
}

