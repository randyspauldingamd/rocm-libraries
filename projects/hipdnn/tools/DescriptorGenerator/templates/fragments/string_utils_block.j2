// Insert into backend/src/BackendEnumStringUtils.hpp

// hipdnnGetBackendDescriptorTypeName() case:
    case {{ op.descriptor_type_enum }}:
        return "{{ op.descriptor_type_enum }}";

// hipdnnGetAttributeNameString() cases:
{% for tf in op.tensor_fields %}
    case {{ op.operation_attr_prefix }}_{{ tf.attr_suffix }}:
        return "{{ op.operation_attr_prefix }}_{{ tf.attr_suffix }}";
{% endfor %}
{% for df in op.data_fields %}
{% if not df.shared %}
    case {{ df.attr_name }}:
        return "{{ df.attr_name }}";
{% endif %}
{% endfor %}
{% if op.has_compute_data_type and not op.compute_data_type_shared %}
    case {{ op.compute_data_type_attr }}:
        return "{{ op.compute_data_type_attr }}";
{% endif %}
{% for taf in op.tensor_array_fields %}
    case {{ taf.attr_name }}:
        return "{{ taf.attr_name }}";
{% endfor %}
