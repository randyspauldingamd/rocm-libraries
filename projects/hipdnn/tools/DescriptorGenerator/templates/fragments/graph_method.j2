// Add this method to the Graph class

    // NOLINTBEGIN(readability-identifier-naming)
{% if op.frontend.graph_return_type == "single" %}
    std::shared_ptr<TensorAttributes> {{ op.effective_graph_method_name }}(
{% for param in op.frontend.graph_method_params %}
        std::shared_ptr<TensorAttributes> {{ param.name }},
{% endfor %}
        {{ op.frontend.attributes_class }} attributes)
{% else %}
    std::tuple<{% for output_name in op.frontend.graph_return_outputs %}std::shared_ptr<TensorAttributes>{% if not loop.last %}, {% endif %}{% endfor %}>
        {{ op.effective_graph_method_name }}(
{% for param in op.frontend.graph_method_params %}
        std::shared_ptr<TensorAttributes> {{ param.name }},
{% endfor %}
        {{ op.frontend.attributes_class }} attributes)
{% endif %}
    // NOLINTEND(readability-identifier-naming)
    {
        if(attributes.get_name().empty())
        {
            attributes.set_name("{{ op.name }}_" + std::to_string(_sub_nodes.size()));
        }
{% for param in op.frontend.graph_method_params %}
{% set tensor_name = param.tensor_name if param.tensor_name else param.name %}
        if({{ param.name }}->get_name().empty())
        {
            {{ param.name }}->set_name(attributes.get_name() + "::{{ tensor_name | upper }}");
        }
{% endfor %}

{% for tensor in op.frontend.outputs %}
        auto {{ tensor.name }} = outputTensor(attributes.get_name() + "::{{ tensor.effective_enum_name }}");
{% endfor %}

{% for param in op.frontend.graph_method_params %}
{% for tensor in op.frontend.inputs %}
{% if tensor.name == (param.tensor_name if param.tensor_name else param.name) %}
        attributes.{{ tensor.effective_setter_name }}(std::move({{ param.name }}));
{% endif %}
{% endfor %}
{% endfor %}
{% for tensor in op.frontend.outputs %}
        attributes.{{ tensor.effective_setter_name }}({{ tensor.name }});
{% endfor %}

        _sub_nodes.emplace_back(
            std::make_shared<{{ op.frontend.node_class }}>(std::move(attributes), graph_attributes));

{% if op.frontend.graph_return_type == "single" %}
{% set first_output = op.frontend.outputs[0] %}
        return {{ first_output.name }};
{% else %}
        return { {% for output_name in op.frontend.graph_return_outputs %}{{ output_name }}{% if not loop.last %}, {% endif %}{% endfor %} };
{% endif %}
    }
