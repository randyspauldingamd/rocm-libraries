TEST_F(Test{{ op.class_name }}, GetAttributeTensorDescriptor)
{
    makeFinalized();
    auto desc = getDescriptor();

    HipdnnBackendDescriptor* retrieved{{ op.tensor_fields[0].pascal_name }} = nullptr;
    int64_t elementCount = 0;
    ASSERT_NO_THROW(desc->getAttribute({{ op.operation_attr_prefix }}_{{ op.tensor_fields[0].attr_suffix }},
                                       HIPDNN_TYPE_BACKEND_DESCRIPTOR,
                                       1,
                                       &elementCount,
                                       static_cast<void*>(&retrieved{{ op.tensor_fields[0].pascal_name }})));

    ASSERT_EQ(elementCount, 1);
    ASSERT_NE(retrieved{{ op.tensor_fields[0].pascal_name }}, nullptr);
    const std::unique_ptr<HipdnnBackendDescriptor> guard{{ op.tensor_fields[0].pascal_name }}(retrieved{{ op.tensor_fields[0].pascal_name }});
}

