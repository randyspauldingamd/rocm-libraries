    {{ cf.test_c_type }} {{ cf.camel_name }} = {{ cf.test_default_value }};
    int64_t {{ cf.camel_name }}Count = 0;
    ASSERT_NO_THROW(desc->getAttribute(
        {{ cf.attr_name }}, {{ cf.backend_type }}, 1, &{{ cf.camel_name }}Count, &{{ cf.camel_name }}));
    ASSERT_EQ({{ cf.camel_name }}Count, 1);
    EXPECT_EQ({{ cf.camel_name }}, {{ cf.test_backend_value }});
