class Test{{ op.class_name }} : public ::testing::Test
{
public:
    std::shared_ptr<{{ op.class_name }}> getDescriptor() const
    {
        return _wrapper->asDescriptor<{{ op.class_name }}>();
    }

    void setTensors() const
    {
        auto desc = getDescriptor();
{% for tf in op.tensor_fields %}
        desc->setAttribute({{ op.operation_attr_prefix }}_{{ tf.attr_suffix }},
                           HIPDNN_TYPE_BACKEND_DESCRIPTOR,
                           1,
                           &{{ tf.member_name }});
{% endfor %}
    }

    void {{ op.effective_test_params_method_name }}() const
    {
        auto desc = getDescriptor();
{% for df in op.data_fields %}
{% if df.is_vector %}
{% set const_name = vector_const_name(df, op) %}
        auto {{ df.camel_name }} = toVec({{ const_name }});
{% endif %}
{% endfor %}

{% for df in op.data_fields %}
{% if df.is_vector %}
        desc->setAttribute(
            {{ df.attr_name }}, {{ df.backend_type }}, {{ op.test_data.field_values.get(df.name, [1, 1]) | length }}, {{ df.camel_name }}.data());
{% endif %}
{% endfor %}
    }

    void setRequiredAttributes() const
    {
        setTensors();
        {{ op.effective_test_params_method_name }}();
{% if op.has_compute_data_type %}
        auto computeType = HIPDNN_DATA_FLOAT;
        getDescriptor()->setAttribute(
            {{ op.compute_data_type_attr }}, HIPDNN_TYPE_DATA_TYPE, 1, &computeType);
{% endif %}
{% for ef in op.enum_fields %}
        auto {{ ef.camel_name }} = static_cast<int64_t>({{ ef.enum_short_type }}::{{ ef.test_enum_value }});
        getDescriptor()->setAttribute(
            {{ ef.attr_name }}, HIPDNN_TYPE_INT64, 1, &{{ ef.camel_name }});
{% endfor %}
{% for cf in op.mode_fields %}
        auto {{ cf.camel_name }} = {{ cf.test_backend_value }};
        getDescriptor()->setAttribute(
            {{ cf.attr_name }}, {{ cf.backend_type }}, 1, &{{ cf.camel_name }});
{% endfor %}
    }

    void makeFinalized() const
    {
        setRequiredAttributes();
        getDescriptor()->finalize();
    }

protected:
    std::unique_ptr<HipdnnBackendDescriptor> _wrapper = nullptr;
{% for tf in op.tensor_fields %}
    std::unique_ptr<HipdnnBackendDescriptor> {{ tf.member_name }} = nullptr;
{% endfor %}
{% for taf in op.tensor_array_fields %}
{% for uid in taf.test_uids %}
    std::unique_ptr<HipdnnBackendDescriptor> _{{ taf.camel_name }}Desc{{ loop.index0 }} = nullptr;
{% endfor %}
{% endfor %}
    std::unique_ptr<HipdnnBackendDescriptor> _unfinalizedTensor = nullptr;

    void SetUp() override
    {
        _wrapper = createDescriptor<{{ op.class_name }}>();
{% for tf in op.tensor_fields %}
{% set tc = op.test_data.tensor_configs.get(tf.name) %}
{% if tc %}
{% set uid_const = op.tensor_const_prefix ~ "TENSOR_" ~ (tf.name | upper) ~ "_UID" %}
{% set dims_const = op.tensor_const_prefix ~ "TENSOR_" ~ (tf.name | upper) ~ "_DIMS" %}
{% set strides_const = op.tensor_const_prefix ~ "TENSOR_" ~ (tf.name | upper) ~ "_STRIDES" %}
        {{ tf.member_name }} = createFinalizedTensor(
            {{ uid_const }}, toVec({{ dims_const }}), toVec({{ strides_const }}));
{% else %}
{% set uid_const = op.tensor_const_prefix ~ "TENSOR_" ~ (tf.name | upper) ~ "_UID" %}
        {{ tf.member_name }} = createFinalizedTensor({{ uid_const }});
{% endif %}
{% endfor %}
{% for taf in op.tensor_array_fields %}
{% for uid in taf.test_uids %}
        _{{ taf.camel_name }}Desc{{ loop.index0 }} = createFinalizedTensor({{ uid }});
{% endfor %}
{% endfor %}
        _unfinalizedTensor = createDescriptor<TensorDescriptor>();
    }

    void TearDown() override
    {
        _wrapper.reset();
{% for tf in op.tensor_fields %}
        {{ tf.member_name }}.reset();
{% endfor %}
{% for taf in op.tensor_array_fields %}
{% for uid in taf.test_uids %}
        _{{ taf.camel_name }}Desc{{ loop.index0 }}.reset();
{% endfor %}
{% endfor %}
        _unfinalizedTensor.reset();
    }
};

