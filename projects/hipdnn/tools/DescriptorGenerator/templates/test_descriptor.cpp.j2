    int64_t {{ vf.camel_name }}Count = 0;
    ASSERT_NO_THROW(desc->getAttribute(
        {{ vf.attr_name }}, {{ vf.backend_type }}, {{ tv | length }}, &{{ vf.camel_name }}Count, {{ vf.camel_name }}.data()));
{% if loop.first %}

    ASSERT_EQ({{ vf.camel_name }}Count, {{ tv | length }});
