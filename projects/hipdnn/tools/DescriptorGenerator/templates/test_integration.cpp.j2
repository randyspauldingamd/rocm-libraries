// Lowers a frontend graph via build_operation_graph_via_descriptors, then
// retrieves the serialized graph and deserializes it for verification.
class Integration{{ op.frontend.attributes_filename or op.name }}DescriptorLowering : public IntegrationTestFixture
{
protected:
    /// Builds and lowers a graph, returning the deserialized GraphT.
    /// Callers set up attrs before calling; this creates tensors, calls the
    /// graph method, validates, lowers, serializes, and deserializes.
    hipdnn_flatbuffers_sdk::data_objects::GraphT buildAndDeserialize(
        {{ op.frontend.attributes_class }}& attrs)
    {
        auto graph = std::make_shared<TestableGraphLowering>();
        graph->set_name("{{ op.name }}IntegrationTest")
            .set_compute_data_type(DataType::FLOAT)
            .set_intermediate_data_type(DataType::FLOAT)
            .set_io_data_type(DataType::FLOAT);

{% set rmap = op.frontend_to_tensor_field_map %}
{% for param in op.frontend.graph_method_params %}
{% set tf_name = rmap.get(param.tensor_name, param.tensor_name) %}
{% set tc = op.test_data.tensor_configs.get(tf_name) %}
        auto {{ param.name }} = std::make_shared<TensorAttributes>();
        {{ param.name }}->set_uid({{ op.tensor_const_prefix }}TENSOR_{{ tf_name | upper }}_UID)
            .set_name("{{ param.tensor_name }}")
            .set_data_type(DataType::FLOAT);
{% if tc %}
        {{ param.name }}->set_dim(toVec({{ op.tensor_const_prefix }}TENSOR_{{ tf_name | upper }}_DIMS)).set_stride(toVec({{ op.tensor_const_prefix }}TENSOR_{{ tf_name | upper }}_STRIDES));
{% endif %}

{% endfor %}
{% if op.frontend.graph_return_type == 'single' %}
{% set out_name = op.frontend.graph_return_outputs[0] %}
{% set out_tf_name = rmap.get(out_name, out_name) %}
{% set out_tc = op.test_data.tensor_configs.get(out_tf_name) %}
        auto {{ out_name }} = graph->{{ op.frontend.graph_method_name }}(
{% for param in op.frontend.graph_method_params %}
            {{ param.name }},
{% endfor %}
            attrs);
        {{ out_name }}->set_uid({{ op.tensor_const_prefix }}TENSOR_{{ out_tf_name | upper }}_UID)
            .set_output(true)
            .set_name("{{ out_name }}");
{% endif %}

        return lowerAndDeserialize(*graph, _handle);
    }
};

{% set non_sentinel = [] %}
{% if op.mode_fields %}
{% set mf = op.mode_fields[0] %}
{% if mf.enum_def %}
{% set non_sentinel = mf.enum_def.non_sentinel_values %}
{% endif %}
{% endif %}
// Lowering round-trip: builds a graph, lowers via descriptors, and verifies
// the deserialized FlatBuffer attributes match.
TEST_F(Integration{{ op.frontend.attributes_filename or op.name }}DescriptorLowering, {{ op.name }}LoweringRoundTrip)
{
    {{ op.frontend.attributes_class }} attrs;
    attrs.set_name("test_op");
{% if op.mode_fields %}
{% set mf = op.mode_fields[0] %}
{% if non_sentinel %}
    attrs.{{ mf.frontend_setter_name }}({{ mf.effective_frontend_type }}::{{ non_sentinel[0].effective_frontend_name }});
{% endif %}
{% endif %}
{% for df in op.data_fields if df.is_vector and df.required %}
{% if df.name in op.test_data.field_values %}
{% set const_name = vector_const_name(df, op) %}
    attrs.{{ df.frontend_setter_name }}(toVec({{ const_name }}));
{% endif %}
{% endfor %}

    auto graphT = buildAndDeserialize(attrs);

    // Verify tensors
    ASSERT_EQ(graphT.tensors.size(), {{ op.required_tensor_fields | length }}u);

    // Verify tensor attributes
    auto tensorMap = buildTensorMap(graphT);
{% for tf in op.required_tensor_fields %}
{% set tf_upper = tf.name | upper %}
{% set tc = op.test_data.tensor_configs.get(tf.name) %}
    ASSERT_NE(tensorMap.count({{ op.tensor_const_prefix }}TENSOR_{{ tf_upper }}_UID), 0u);
{% if tc %}
    EXPECT_EQ(tensorMap[{{ op.tensor_const_prefix }}TENSOR_{{ tf_upper }}_UID]->dims, toVec({{ op.tensor_const_prefix }}TENSOR_{{ tf_upper }}_DIMS));
    EXPECT_EQ(tensorMap[{{ op.tensor_const_prefix }}TENSOR_{{ tf_upper }}_UID]->strides, toVec({{ op.tensor_const_prefix }}TENSOR_{{ tf_upper }}_STRIDES));
{% endif %}
    EXPECT_EQ(tensorMap[{{ op.tensor_const_prefix }}TENSOR_{{ tf_upper }}_UID]->data_type, DataTypeSdk::FLOAT);
{% endfor %}

    // Verify operation node
    ASSERT_EQ(graphT.nodes.size(), 1u);
    auto& node = graphT.nodes[0];
    EXPECT_EQ(node->compute_data_type, DataTypeSdk::FLOAT);
{% if op.frontend.node_attributes_union_type %}
    EXPECT_EQ(node->attributes.type, NodeAttrType::{{ op.frontend.node_attributes_union_type }});
{% endif %}

    auto* opNode = node->attributes.As{{ op.fbs_table }}();
    ASSERT_NE(opNode, nullptr);

    // Verify required tensor UIDs
{% for tf in op.required_tensor_fields %}
    EXPECT_EQ(opNode->{{ tf.fbs_field }}, {{ op.tensor_const_prefix }}TENSOR_{{ tf.name | upper }}_UID);
{% endfor %}

    // Verify operation name preserved through lowering
    EXPECT_EQ(node->name, "test_op");

{% if op.mode_fields %}
{% set mf = op.mode_fields[0] %}
    // Verify mode
{% if non_sentinel %}
    EXPECT_EQ(opNode->{{ mf.fbs_field }}, {{ mf.enum_short_type }}Sdk::{{ non_sentinel[0].effective_sdk_name }});
{% endif %}
{% endif %}

{% for df in op.data_fields if df.is_vector and df.required %}
{% if df.name in op.test_data.field_values %}
{% set const_name = vector_const_name(df, op) %}
    // Verify {{ df.name }}
    EXPECT_EQ(opNode->{{ df.fbs_field }}, toVec({{ const_name }}));
{% endif %}
{% endfor %}
}

{% for df in op.optional_scalar_fields %}
{% if df.type == 'scalar_float' %}
{% set test_val = '0.5F' %}
{% elif df.type == 'scalar_int64' %}
{% set test_val = '2' %}
{% elif df.type == 'bool' %}
{% set test_val = 'true' %}
{% else %}
{% set test_val = '1' %}
{% endif %}
// Verifies that the optional {{ df.name }} attribute survives lowering round-trip.
TEST_F(Integration{{ op.frontend.attributes_filename or op.name }}DescriptorLowering, {{ df.pascal_name }}PreservedInRoundTrip)
{
    {{ op.frontend.attributes_class }} attrs;
    attrs.set_name("test_{{ df.name }}");
{% if op.mode_fields %}
{% set mf = op.mode_fields[0] %}
{% if non_sentinel %}
    attrs.{{ mf.frontend_setter_name }}({{ mf.effective_frontend_type }}::{{ non_sentinel[0].effective_frontend_name }});
{% endif %}
{% endif %}
{% for vf in op.data_fields if vf.is_vector and vf.required %}
{% if vf.name in op.test_data.field_values %}
{% set const_name = vector_const_name(vf, op) %}
    attrs.{{ vf.frontend_setter_name }}(toVec({{ const_name }}));
{% endif %}
{% endfor %}
    attrs.{{ df.frontend_setter_name }}({{ test_val }});

    auto graphT = buildAndDeserialize(attrs);

    ASSERT_EQ(graphT.nodes.size(), 1u);
    auto* opNode = graphT.nodes[0]->attributes.As{{ op.fbs_table }}();
    ASSERT_NE(opNode, nullptr);

    ASSERT_TRUE(opNode->{{ df.fbs_field }}.has_value());
{% if df.type == 'scalar_float' %}
    EXPECT_FLOAT_EQ(opNode->{{ df.fbs_field }}.value(), {{ test_val }});
{% else %}
    EXPECT_EQ(opNode->{{ df.fbs_field }}.value(), {{ test_val }});
{% endif %}
}

{% endfor %}
