void {{ op.class_name }}::getAttribute(hipdnnBackendAttributeName_t attributeName,
                                                     hipdnnBackendAttributeType_t attributeType,
                                                     int64_t requestedElementCount,
                                                     int64_t* elementCount,
                                                     void* arrayOfElements) const
{
    THROW_IF_FALSE(isFinalized(),
                   HIPDNN_STATUS_NOT_INITIALIZED,
                   "{{ op.class_name }}::getAttribute() failed: Not finalized.");

    switch(attributeName)
    {
{% for tf in op.tensor_fields %}
    case {{ op.operation_attr_prefix }}_{{ tf.attr_suffix }}:
{% if tf.required %}
        getTensorDescriptor({{ tf.member_name }},
{% else %}
        getOptionalTensorDescriptor({{ tf.member_name }},
{% endif %}
                            attributeType,
                            requestedElementCount,
                            elementCount,
                            arrayOfElements,
                            "{{ op.class_name }}::getAttribute()");
        break;
{% endfor %}
{% for df in op.data_fields %}
{% if df.is_vector %}
    case {{ df.attr_name }}:
        getScalarVector<{{ df.cpp_type }}>(_data.{{ df.fbs_field }},
                       {{ df.backend_type }},
                       attributeType,
                       requestedElementCount,
                       elementCount,
                       arrayOfElements,
                       "{{ op.class_name }}::getAttribute()");
        break;
{% elif df.is_mode %}
    case {{ df.attr_name }}:
        {{ df.backend_getter }}(_data.{{ df.fbs_field }},
                    attributeType,
                    requestedElementCount,
                    elementCount,
                    arrayOfElements,
                    "{{ op.class_name }}::getAttribute()");
        break;
{% elif df.is_enum %}
    case {{ df.attr_name }}:
        {{ df.getter_helper_name }}(attributeType, requestedElementCount, elementCount, arrayOfElements);
        break;
{% elif df.is_optional_scalar %}
    case {{ df.attr_name }}:
        getOptionalScalar<{{ df.backend_type }}>(_data.{{ df.fbs_field }},
                  attributeType,
                  requestedElementCount,
                  elementCount,
                  arrayOfElements,
                  "{{ op.class_name }}::getAttribute()");
        break;
{% elif df.is_scalar %}
    case {{ df.attr_name }}:
        getScalar(_data.{{ df.fbs_field }},
                  {{ df.backend_type }},
                  attributeType,
                  requestedElementCount,
                  elementCount,
                  arrayOfElements,
                  "{{ op.class_name }}::getAttribute()");
        break;
{% endif %}
{% endfor %}
{% if op.has_compute_data_type %}
    case {{ op.compute_data_type_attr }}:
        getDataType(_computeDataType,
                    attributeType,
                    requestedElementCount,
                    elementCount,
                    arrayOfElements,
                    "{{ op.class_name }}::getAttribute()");
        break;
{% endif %}
{% for taf in op.tensor_array_fields %}
    case {{ taf.attr_name }}:
        getTensorArrayDesc(
            attributeName, attributeType, requestedElementCount, elementCount, arrayOfElements);
        break;
{% endfor %}
    case HIPDNN_ATTR_OPERATION_NAME_EXT:
        getString(_name,
                  attributeType,
                  requestedElementCount,
                  elementCount,
                  arrayOfElements,
                  "{{ op.class_name }}::getAttribute()");
        break;
{% if op.operation_type_enum %}
    case HIPDNN_ATTR_OPERATION_TYPE_EXT:
        getOperationType({{ op.operation_type_enum }},
                         attributeType,
                         requestedElementCount,
                         elementCount,
                         arrayOfElements,
                         "{{ op.class_name }}::getAttribute()");
        break;
{% endif %}
    default:
        throw HipdnnException(HIPDNN_STATUS_NOT_SUPPORTED,
                              "{{ op.class_name }}::getAttribute: attributeName not "
                              "supported");
    }
}
{% for ef in op.enum_fields %}

void {{ op.class_name }}::{{ ef.getter_helper_name }}(hipdnnBackendAttributeType_t attributeType,
                                                    int64_t requestedElementCount,
                                                    int64_t* elementCount,
                                                    void* arrayOfElements) const
{
    checkGetArgs(
        HIPDNN_TYPE_INT64, attributeType, "{{ op.class_name }}::getAttribute()");

    if(arrayOfElements == nullptr || requestedElementCount == 0)
    {
        THROW_IF_NULL(elementCount,
                      HIPDNN_STATUS_BAD_PARAM_NULL_POINTER,
                      "{{ op.class_name }}::getAttribute(): elementCount is null");
        *elementCount = 1;
        return;
    }

    THROW_IF_FALSE(requestedElementCount >= 1,
                   HIPDNN_STATUS_BAD_PARAM,
                   "{{ op.class_name }}::getAttribute(): requestedElementCount < 1");

    if(elementCount != nullptr)
    {
        *elementCount = 1;
    }
    *static_cast<int64_t*>(arrayOfElements) = static_cast<int64_t>(_data.{{ ef.fbs_field }});
}
{% endfor %}
{% if op.has_tensor_array_fields %}

void {{ op.class_name }}::getTensorArrayDesc(hipdnnBackendAttributeName_t attributeName,
                                                            hipdnnBackendAttributeType_t attributeType,
                                                            int64_t requestedElementCount,
                                                            int64_t* elementCount,
                                                            void* arrayOfElements) const
{
    switch(attributeName)
    {
{% for taf in op.tensor_array_fields %}
    case {{ taf.attr_name }}:
        getTensorDescriptorArray(_{{ taf.name }}Descs,
                                 attributeType,
                                 requestedElementCount,
                                 elementCount,
                                 arrayOfElements,
                                 "{{ op.class_name }}::getAttribute()");
        break;
{% endfor %}
    default:
        throw HipdnnException(HIPDNN_STATUS_BAD_PARAM,
                              "{{ op.class_name }}::getTensorArrayDesc(): unsupported "
                              "attribute name");
    }
}
{%- endif %}

