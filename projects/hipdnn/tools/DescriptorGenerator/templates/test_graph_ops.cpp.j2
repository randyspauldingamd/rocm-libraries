                      {{ uid_const }}{% if not loop.last or op.graph_verifiable_data_fields %},{% endif %}

{% endfor %}
{% for df in op.graph_verifiable_data_fields %}
{% if df.is_vector %}
{% set const_name = vector_const_name(df, op) %}
                      toVec({{ const_name }}){% if not loop.last %},{% endif %}

{% elif df.is_mode %}
                      {{ df.enum_short_type }}::{{ df.test_enum_value }}{% if not loop.last %},{% endif %}

{% elif df.is_enum %}
                      {{ df.enum_short_type }}::{{ df.test_enum_value }}{% if not loop.last %},{% endif %}

{% endif %}
{% endfor %}
);
{% else %}
    ASSERT_EQ(graphT->nodes[0]->attributes.type, NodeAttributes::{{ op.node_attributes_union_member }});

    auto* attrs = graphT->nodes[0]->attributes.As{{ op.fbs_table }}();
    ASSERT_NE(attrs, nullptr);
{% if op.has_compute_data_type %}
    EXPECT_EQ(graphT->nodes[0]->compute_data_type, DataType::FLOAT);
{% endif %}

    // Verify tensor UID references
{% for tf in op.tensor_fields %}
{% set uid_const = op.tensor_const_prefix ~ "TENSOR_" ~ (tf.name | upper) ~ "_UID" %}
    EXPECT_EQ(attrs->{{ tf.uid_field }}, {{ uid_const }});
{% endfor %}
{% endif %}
{% for taf in op.tensor_array_fields %}

    // Verify {{ taf.name }} tensor array is empty (not set in basic test)
    EXPECT_EQ(graphT->nodes[0]->attributes.As{{ op.fbs_table }}()->{{ taf.fbs_field }}.size(), 0u);
{% endfor %}

    // Verify default node name is empty
    EXPECT_TRUE(graphT->nodes[0]->name.empty());
