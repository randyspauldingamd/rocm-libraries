// Helper: create a finalized {{ op.class_name }} from tensor descriptors
inline std::unique_ptr<HipdnnBackendDescriptor>
    createFinalized{{ op.name }}Op({% for tf in op.tensor_fields %}HipdnnBackendDescriptor* {{ tf.local_desc_name }}{% if not loop.last %},
                          {% endif %}{% endfor %}{% if op.has_tensor_array_fields %},
{% for taf in op.tensor_array_fields %}
                          std::vector<HipdnnBackendDescriptor*> {{ taf.camel_name }}Descs = {}{% if not loop.last %},{% endif %}
{% endfor %}{% endif %},
                          hipdnnDataType_t computeType = HIPDNN_DATA_FLOAT,
                          const std::string& name = "")
{
    auto wrapper = createDescriptor<{{ op.class_name }}>();
    auto desc = wrapper->asDescriptor<{{ op.class_name }}>();

{% for tf in op.tensor_fields %}
    desc->setAttribute(
        {{ op.operation_attr_prefix }}_{{ tf.attr_suffix }}, HIPDNN_TYPE_BACKEND_DESCRIPTOR, 1,
        static_cast<const void*>(&{{ tf.local_desc_name }}));
{% endfor %}
{% for df in op.required_data_fields %}
{% if df.is_vector %}
{% set const_name = vector_const_name(df, op) %}

    auto {{ df.camel_name }} = toVec({{ const_name }});
    desc->setAttribute({{ df.attr_name }}, {{ df.backend_type }}, static_cast<int64_t>({{ df.camel_name }}.size()), {{ df.camel_name }}.data());
{% elif df.is_mode %}

    auto {{ df.camel_name }} = {{ df.test_backend_value }};
    desc->setAttribute({{ df.attr_name }}, {{ df.backend_type }}, 1, &{{ df.camel_name }});
{% elif df.is_enum %}

    auto {{ df.camel_name }} = static_cast<int64_t>({{ df.enum_short_type }}::{{ df.test_enum_value }});
    desc->setAttribute({{ df.attr_name }}, HIPDNN_TYPE_INT64, 1, &{{ df.camel_name }});
{% endif %}
{% endfor %}
{% if op.has_compute_data_type %}
    desc->setAttribute({{ op.compute_data_type_attr }}, HIPDNN_TYPE_DATA_TYPE, 1, &computeType);
{% endif %}
{% for taf in op.tensor_array_fields %}

    if(!{{ taf.camel_name }}Descs.empty())
    {
        desc->setAttribute(
            {{ taf.attr_name }}, HIPDNN_TYPE_BACKEND_DESCRIPTOR,
            static_cast<int64_t>({{ taf.camel_name }}Descs.size()),
            static_cast<const void*>({{ taf.camel_name }}Descs.data()));
    }
{% endfor %}

    if(!name.empty())
    {
        desc->setAttribute(HIPDNN_ATTR_OPERATION_NAME_EXT,
                           HIPDNN_TYPE_CHAR,
                           static_cast<int64_t>(name.size()),
                           name.data());
    }

    desc->finalize();
    return wrapper;
}

class TestGraphDescriptor{{ op.name }} : public ::testing::Test
{
public:
    std::shared_ptr<GraphDescriptor> getDescriptor() const
    {
        return _wrapper->asDescriptor<GraphDescriptor>();
    }

    void setHandle() const
    {
        auto desc = getDescriptor();
        hipdnnHandle_t handle = &_mockHandle;
        desc->setAttribute(HIPDNN_ATTR_OPERATIONGRAPH_HANDLE, HIPDNN_TYPE_HANDLE, 1,
                           static_cast<const void*>(&handle));
    }

    static const TensorAttributesT* findTensorByUid(const GraphT& graphT, int64_t uid)
    {
        for(const auto& tensor : graphT.tensors)
        {
            if(tensor->uid == uid)
            {
                return tensor.get();
            }
        }
        return nullptr;
    }

    static void verifyTensor(const TensorAttributesT* tensor,
                             int64_t expectedUid,
                             const std::vector<int64_t>& expectedDims,
                             const std::vector<int64_t>& expectedStrides,
                             DataType expectedDataType,
                             bool expectedVirtual = false)
    {
        ASSERT_NE(tensor, nullptr) << "Tensor with UID " << expectedUid << " not found"; // NOLINT(readability-implicit-bool-conversion)
        EXPECT_EQ(tensor->uid, expectedUid);
        EXPECT_EQ(tensor->dims, expectedDims);
        EXPECT_EQ(tensor->strides, expectedStrides);
        EXPECT_EQ(tensor->data_type, expectedDataType);
        EXPECT_EQ(tensor->virtual_, expectedVirtual);
    }

{% if op.graph_verifiable_data_fields %}
    static void verify{{ op.name }}Node(const NodeT& node,
{% if op.has_compute_data_type %}
                                  DataType expectedComputeType,
{% endif %}
{% for tf in op.tensor_fields %}
                                  int64_t expected{{ tf.pascal_name }}Uid{% if not loop.last or op.graph_verifiable_data_fields %},{% endif %}

{% endfor %}
{% for df in op.graph_verifiable_data_fields %}
{% if df.is_vector %}
                                  const std::vector<int64_t>& expected{{ df.name | replace('_', ' ') | title | replace(' ', '') }}{% if not loop.last %},{% endif %}

{% elif df.is_mode %}
                                  {{ df.enum_short_type }} expected{{ df.enum_short_type }}{% if not loop.last %},{% endif %}

{% elif df.is_enum %}
                                  {{ df.enum_short_type }} expected{{ df.enum_short_type }}{% if not loop.last %},{% endif %}

{% endif %}
{% endfor %}
)
    {
{% if op.has_compute_data_type %}
        EXPECT_EQ(node.compute_data_type, expectedComputeType);
{% endif %}
        ASSERT_EQ(node.attributes.type, NodeAttributes::{{ op.node_attributes_union_member }});

        auto* attrs = node.attributes.As{{ op.fbs_table }}();
        ASSERT_NE(attrs, nullptr);

{% for tf in op.tensor_fields %}
        EXPECT_EQ(attrs->{{ tf.uid_field }}, expected{{ tf.pascal_name }}Uid);
{% endfor %}
{% for df in op.data_fields %}
{% if df.is_vector %}
        EXPECT_EQ(attrs->{{ df.fbs_field }}, expected{{ df.name | replace('_', ' ') | title | replace(' ', '') }});
{% elif df.is_mode %}
        EXPECT_EQ(attrs->{{ df.fbs_field }}, expected{{ df.enum_short_type }});
{% elif df.is_enum %}
        EXPECT_EQ(attrs->{{ df.fbs_field }}, expected{{ df.enum_short_type }});
{% endif %}
{% endfor %}
    }
{% endif %}

protected:
    std::unique_ptr<HipdnnBackendDescriptor> _wrapper = nullptr;
    mutable MockHandle _mockHandle;

    void SetUp() override
    {
        _wrapper = createDescriptor<GraphDescriptor>();
    }

    void TearDown() override
    {
        _wrapper.reset();
    }
};

