TEST_F(Test{{ op.name }}OperationFromNode, NamePreservedFromNode)
{
    auto node = createStandardNode();
    node.name = "test_{{ op.name | lower }}_1";

    auto desc = {{ op.class_name }}::fromNode(node, _tensorMap);

    int64_t count = 0;
    desc->getAttribute(HIPDNN_ATTR_OPERATION_NAME_EXT, HIPDNN_TYPE_CHAR, 0, &count, nullptr);
    ASSERT_EQ(count, static_cast<int64_t>(std::string("test_{{ op.name | lower }}_1").size() + 1));

    std::vector<char> buffer(static_cast<size_t>(count));
    int64_t actualCount = 0;
    desc->getAttribute(
        HIPDNN_ATTR_OPERATION_NAME_EXT, HIPDNN_TYPE_CHAR, count, &actualCount, buffer.data());
    EXPECT_STREQ(buffer.data(), "test_{{ op.name | lower }}_1");
}

