# Full dnn-benchmark config example.
#
# All public config-supported options are shown here. CLI flags override config
# values, so this file can be used as a base recipe and adjusted per run:
#   dnn-benchmark --config sample_configs/config.toml.example --graph graphs/sample_conv_fwd.json --iters 500
#
# Relative paths are resolved from this config file's directory.

# Config schema version. Currently only version 1 is supported.
version = 1

# Workloads to run. Commonly overridden with --graph/-g per run.
graphs = [
  "../graphs/sample_conv_fwd.json",
]

# Benchmark loop controls.
warmup = 10
iters = 100

# Optional seed for reproducible input data. Use an integer, or omit/null for no fixed seed.
seed = 123

# Execution backend: "hipdnn" or "pytorch". Both support single-graph, glob,
# tarball, and multi-graph suite execution.
backend = "hipdnn"

# Output JSON path for the full SuiteResult. Omit or set null to disable JSON output.
output = "results.json"

# Verbose console output. true matches --verbose/-v; false keeps the summary table.
verbose = false

# Correctness validation tolerances and provider.
rtol = 1e-5
atol = 1e-8
validate = "none"  # "none" or "pytorch"

# Optional plugin discovery directory. setup.sh prints the selected prefix; pass
# <selected-prefix>/lib/hipdnn_plugins/engines when plugin discovery is not
# already configured by the runtime environment.
# plugin_path = "<selected-prefix>/lib/hipdnn_plugins/engines"

# Always-on metrics tier: "basic" or "off".
metrics_tier = "basic"

# Optional profiling passes. Omit these keys to disable each optional pass.
# emit_trace = "pftrace"  # "pftrace" or "kineto"
# pmc = "basic"           # "basic", "memory", "flops", or "all"
pmc_allow_multipass = false
perf = false
roofline = false

# Root directory for profiling artifacts. Only used when an optional profiling pass is enabled.
# profiling_output_dir = "profiling-output"

# Timeout in seconds for each external profiler subprocess. Use 0 to disable the timeout.
profiling_timeout = 600

# Optional explicit engine matrix. Uncomment to run only specific engine IDs.
# If any engine entry sets plugin_path, every engine entry must set plugin_path.
# When either --engine or --plugin-path is supplied on the CLI, this matrix is
# ignored as a unit so CLI engine/plugin selections do not mix with config ones.
#
# [[engines]]
# id = 1
# plugin_path = "<selected-prefix>/lib/hipdnn_plugins/engines"
#
# [[engines]]
# id = 2
# plugin_path = "/path/to/alternate/hipdnn_plugins/engines"
