#include "../../instance_includes.inc"
namespace ck_tile::builder::profiling {
constexpr auto SIGNATURE = gen_signature;
std::tuple<bool, float, std::string> run_gen_instance_name(const ckt::Args<SIGNATURE>& args,
                                                           const ckt::Inputs<SIGNATURE>& inputs,
                                                           const ckt::Outputs<SIGNATURE>& outputs,
                                                           const ck_tile::stream_config& s_conf)
{
    constexpr auto ALGORITHM =
        cku::ConvAlgorithm_Tile_DepthwiseConvolutionKernel{}.with_depthwise_params(
            ckt::DepthwiseConvParams{.block_size = gen_block_size,
                                     .tile_h     = gen_tile_h,
                                     .tile_w     = gen_tile_w,
                                     .filter_h   = gen_filter_h,
                                     .filter_w   = gen_filter_w,
                                     .stride_h   = gen_stride_h,
                                     .stride_w   = gen_stride_w,
                                     .dilation_h = gen_dilation_h,
                                     .dilation_w = gen_dilation_w,
                                     .pad_h      = gen_pad_h,
                                     .pad_w      = gen_pad_w,
                                     .nbatch     = gen_nbatch,
                                     .subtile_h  = gen_subtile_h,
                                     .subtile_w  = gen_subtile_w,
                                     .in_vec     = gen_in_vec,
                                     .out_vec    = gen_out_vec});
#include "../../instance_run.inc"
}
} // namespace ck_tile::builder::profiling
