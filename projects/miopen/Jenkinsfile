    post {
        success {
            script {
                node {
                    utils.setGithubStatus('Math CI Summary', 'success', 'All checks have passed')
                }
            }
        }
        failure {
            script {
                node {
                    utils.setGithubStatus('Math CI Summary', 'failure', 'Some checks have failed')
                    utils.sendTeamsFailureNotification(buildTheRock: params.BUILD_THEROCK_DOCKER)
                }
            }
        }
