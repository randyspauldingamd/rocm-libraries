  '''
  Invalid parameter value: SFCWGM = [[0, -1]]
  GridDim -1 out of range [0,256)
  '''
# ---
# name: test_space_fill_algo_wgm_invalid_raises[dim_too_big]
  '''
  Invalid parameter value: SFCWGM = [[0, 256]]
  GridDim 256 out of range [0,256)
  '''
# ---
# name: test_space_fill_algo_wgm_invalid_raises[int]
  '''
  Invalid parameter value: SFCWGM = 7
  Must be a nested list of values
  '''
# ---
