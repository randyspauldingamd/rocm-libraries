  '''
  Invalid parameter value: SFCWGM = xy
  Must be a nested list of values
  '''
# ---
# name: test_space_fill_algo_wgm_invalid_raises[too_many_levels]
  '''
  Invalid parameter value: SFCWGM = [[0, 1], [2, 3], [4, 5]]
  Only 3 level ordering supported
  '''
