# name: test_space_fill_algo_invalid_raises[int]
  '''
  Invalid parameter value: SpaceFillingAlgo = 5
  Must be a list of values
  '''
# ---
# name: test_space_fill_algo_invalid_raises[order_negative]
  '''
  Invalid parameter value: SpaceFillingAlgo = [-1, 0]
  OrderID out of range
  '''
# ---
# name: test_space_fill_algo_invalid_raises[order_too_big]
  '''
  Invalid parameter value: SpaceFillingAlgo = [0, 6]
  OrderID out of range
  '''
