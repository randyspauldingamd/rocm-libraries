  '''
  Invalid parameter value: SpaceFillingAlgo = abc
  Must be a list of values
  '''
# ---
# name: test_space_fill_algo_invalid_raises[too_long]
  '''
  Invalid parameter value: SpaceFillingAlgo = [0, 1, 2, 3]
  Only 3 level ordering supported
  '''
# ---
# name: test_space_fill_algo_invalid_raises[tuple]
  '''
  Invalid parameter value: SpaceFillingAlgo = (0, 1)
  Must be a list of values
  '''
