## HIP/GPU Code Patterns

```cpp
// Device function
__device__ void kernel_helper(float* data, int idx)
{
    data[idx] = data[idx] * 2.0f;
}

// Kernel launch
__global__ void my_kernel(float* data, int n)
{
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    if(idx < n)
    {
        kernel_helper(data, idx);
    }
}

// Host code launching kernel
hipLaunchKernelGGL(my_kernel,
                   dim3(blocks),
                   dim3(threads),
                   0,  // shared memory
                   stream,
                   data,
                   n);
```
